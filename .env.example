# Required: shared bearer token for all Polaris API access.
# Generate one: openssl rand -hex 32
POLARIS_AUTH_TOKEN=changeme-set-a-real-token-here

# HTTP server bind address. Default localhost only.
# Set to 0.0.0.0 only if you intend to expose Polaris on a network interface
# (and put it behind a TLS-terminating reverse proxy).
POLARIS_HOST=127.0.0.1

# HTTP server port.
POLARIS_PORT=3000
