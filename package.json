{
  "name": "@onestepat4time/polaris",
  "version": "0.27.0",
  "private": true,
  "description": "Self-hosted lean control plane for AI coding agents. Delegate via API, monitor live.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OneStepAt4time/polaris.git"
  },
  "homepage": "https://github.com/OneStepAt4time/polaris#readme",
  "bugs": {
    "url": "https://github.com/OneStepAt4time/polaris/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "polaris": "./dist/server.js"
  },
  "files": ["dist", "CHARTER.md", "README.md", "LICENSE"],
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run build:ui && tsc -p tsconfig.build.json",
    "build:ui": "astro build",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "budget-check": "node scripts/budget-check.mjs",
    "bench:ingest": "npm run build && node scripts/bench-ingest.mjs",
    "bench:metrics": "npm run build && node scripts/bench-metrics.mjs",
    "bench": "npm run bench:ingest && node scripts/bench-metrics.mjs",
    "gate": "npm run typecheck && npm run lint && npm run build:ui && npm run test && npm run budget-check"
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "^0.36.1",
    "@fastify/sensible": "^6.0.0",
    "@fastify/static": "^8.0.0",
    "better-sqlite3": "^12.0.0",
    "fastify": "^5.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "astro": "^4.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
