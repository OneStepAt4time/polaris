---
const title = "Polaris";
const tagline = "Self-hosted observatory for your AI coding agents";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — {tagline}</title>
    <style is:global>
      * {
        box-sizing: border-box;
      }
      :root {
        --bg: #0a0a0a;
        --bg-card: #15151a;
        --fg: #e5e5e5;
        --fg-dim: #8a8a8a;
        --accent: #ffd54a;
        --border: #2a2a2a;
        --danger: #ff6666;
        --success: #66cc66;
      }
      body {
        font-family: ui-monospace, "SF Mono", Consolas, "Liberation Mono", monospace;
        background: var(--bg);
        color: var(--fg);
        margin: 0;
        padding: 2rem 1.5rem;
        max-width: 1200px;
        margin-inline: auto;
        line-height: 1.5;
      }
      h1 {
        color: var(--accent);
        margin: 0;
        font-size: 1.5rem;
        letter-spacing: 0.04em;
      }
      h2 {
        font-size: 1rem;
        color: var(--fg);
        margin: 1.5rem 0 0.5rem;
      }
      .tagline {
        color: var(--fg-dim);
        margin: 0 0 2rem;
        font-size: 0.875rem;
      }
      .kpis {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 0.75rem;
        margin: 1.5rem 0;
      }
      .kpi {
        background: var(--bg-card);
        padding: 0.875rem 1rem;
        border-left: 3px solid var(--accent);
      }
      .kpi-label {
        font-size: 0.7rem;
        color: var(--fg-dim);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .kpi-value {
        font-size: 1.4rem;
        color: var(--fg);
        margin-top: 0.25rem;
      }
      .delta {
        font-size: 0.7rem;
        margin-left: 0.4rem;
        padding: 0.05rem 0.35rem;
        border-radius: 3px;
        font-weight: 600;
        vertical-align: 4px;
        font-variant-numeric: tabular-nums;
      }
      .delta.up {
        background: rgba(255, 102, 102, 0.15);
        color: var(--danger);
      }
      .delta.down {
        background: rgba(102, 204, 102, 0.18);
        color: var(--success);
      }
      .per-model {
        margin-top: 2rem;
      }
      .model-row {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 1rem;
        padding: 0.5rem 0;
        border-bottom: 1px solid var(--border);
        font-size: 0.875rem;
      }
      .model-row.header {
        color: var(--fg-dim);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      form.token-form {
        display: flex;
        gap: 0.5rem;
        margin: 1.5rem 0;
        max-width: 480px;
      }
      input,
      button,
      textarea {
        font-family: inherit;
        font-size: 0.875rem;
      }
      input,
      textarea {
        background: var(--bg-card);
        border: 1px solid var(--border);
        color: var(--fg);
        padding: 0.5rem 0.75rem;
        flex: 1;
      }
      textarea {
        resize: vertical;
        min-height: 64px;
        width: 100%;
        display: block;
      }
      button {
        background: var(--accent);
        color: #000;
        border: none;
        padding: 0.5rem 1rem;
        cursor: pointer;
        font-weight: 600;
      }
      button.secondary {
        background: var(--bg-card);
        color: var(--fg);
        border: 1px solid var(--border);
        font-weight: 400;
      }
      button.danger {
        background: transparent;
        color: var(--danger);
        border: 1px solid var(--danger);
        font-weight: 400;
      }
      button.success {
        background: var(--success);
        color: #000;
      }
      .tabs,
      .range-tabs {
        display: flex;
        gap: 0.5rem;
        margin: 1rem 0;
      }
      .tabs button,
      .range-tabs button {
        background: var(--bg-card);
        color: var(--fg);
        border: 1px solid var(--border);
        font-weight: normal;
      }
      .tabs button.active,
      .range-tabs button.active {
        background: var(--accent);
        color: #000;
        border-color: var(--accent);
        font-weight: 600;
      }
      .error {
        color: var(--danger);
      }
      .muted {
        color: var(--fg-dim);
      }
      a {
        color: var(--accent);
      }
      .logout {
        background: transparent;
        color: var(--fg-dim);
        border: 1px solid var(--border);
        font-size: 0.75rem;
        padding: 0.25rem 0.5rem;
        margin-left: auto;
      }
      .session-card {
        background: var(--bg-card);
        padding: 1rem;
        margin: 0.75rem 0;
        border-left: 3px solid var(--accent);
        cursor: pointer;
      }
      .session-card.selected {
        border-left-color: var(--success);
      }
      .session-header {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        font-size: 0.8125rem;
      }
      .session-id {
        font-family: inherit;
        color: var(--fg-dim);
      }
      .session-cwd {
        color: var(--fg);
      }
      .tab-badge {
        display: inline-block;
        background: var(--accent);
        color: #000;
        font-size: 0.65rem;
        font-weight: 600;
        padding: 0 0.4rem;
        border-radius: 999px;
        margin-left: 0.4rem;
        min-width: 1.2em;
        text-align: center;
        vertical-align: 1px;
      }
      .tab-badge[hidden] {
        display: none;
      }
      .session-card.needs-approval {
        border-left-color: #ffaa00;
      }
      .session-card.ended {
        opacity: 0.7;
      }
      .session-card.ended .session-cwd {
        text-decoration: line-through;
        text-decoration-color: var(--fg-dim);
      }
      .session-resume {
        margin-top: 0.4rem;
        font-size: 0.72rem;
        padding: 0.25rem 0.5rem;
      }
      .session-card.needs-approval::after {
        content: " · needs approval";
        color: #ffaa00;
        font-size: 0.72rem;
        margin-left: 0.4rem;
      }
      .session-settings {
        font-size: 0.7rem;
        color: var(--fg-dim);
        margin-top: 0.35rem;
        word-break: break-all;
      }
      .session-settings.warning {
        color: #ffaa00;
      }
      .session-settings code {
        background: rgba(255, 255, 255, 0.06);
        padding: 0 0.25rem;
        border-radius: 2px;
        font-size: 0.68rem;
        color: var(--fg);
      }
      .new-session {
        display: flex;
        gap: 0.5rem;
        margin: 1rem 0;
      }
      .new-session input {
        flex: 1;
      }
      .prompt-form {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin: 1rem 0;
      }
      .prompt-form .row {
        display: flex;
        gap: 0.5rem;
      }
      .response-pane {
        background: var(--bg-card);
        border: 1px solid var(--border);
        padding: 0.75rem 1rem;
        margin-top: 1rem;
        font-size: 0.8125rem;
        white-space: pre-wrap;
        max-height: 360px;
        overflow-y: auto;
      }
      .log-entry {
        display: flex;
        gap: 0.5rem;
        padding: 0.2rem 0;
        border-bottom: 1px solid var(--border);
        font-size: 0.75rem;
      }
      .log-entry:last-child {
        border-bottom: none;
      }
      .log-time {
        color: var(--fg-dim);
        flex: 0 0 auto;
        font-variant-numeric: tabular-nums;
      }
      .log-kind {
        color: var(--fg-dim);
        flex: 0 0 auto;
      }
      .log-body {
        flex: 1;
        word-break: break-word;
      }
      .log-entry.approval {
        background: rgba(255, 213, 74, 0.08);
        border-left: 3px solid var(--accent);
        padding-left: 0.5rem;
      }
      .log-entry.closed .log-kind {
        color: var(--success);
      }
      .log-actions {
        display: flex;
        gap: 0.4rem;
        margin-top: 0.4rem;
      }
      .log-actions button {
        font-size: 0.75rem;
        padding: 0.3rem 0.6rem;
      }
      .log-entry.assistant {
        background: rgba(255, 213, 74, 0.04);
        padding: 0.5rem 0.6rem;
      }
      .log-entry.assistant .log-kind {
        color: var(--accent);
      }
      .log-entry.thinking {
        opacity: 0.55;
      }
      .log-entry.thinking .log-body {
        font-style: italic;
      }
      .log-body.markdown {
        font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
        font-size: 0.8125rem;
        line-height: 1.5;
        white-space: normal;
        word-break: break-word;
      }
      .log-body.markdown p {
        margin: 0.25rem 0;
      }
      .log-body.markdown ul {
        margin: 0.25rem 0;
        padding-left: 1.2rem;
      }
      .log-body.markdown a {
        color: var(--accent);
      }
      .code-block {
        background: #0a0a0a;
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 0.5rem 0.75rem;
        margin: 0.4rem 0;
        overflow-x: auto;
        font-size: 0.75rem;
        line-height: 1.4;
      }
      .inline-code {
        background: #0a0a0a;
        border: 1px solid var(--border);
        padding: 0 0.25rem;
        border-radius: 3px;
        font-size: 0.78rem;
      }
      .tool-call {
        border: 1px solid var(--border);
        border-radius: 4px;
        background: #15151a;
        padding: 0.5rem 0.75rem;
        margin: 0.3rem 0;
        font-size: 0.78rem;
      }
      .tool-call-header {
        display: flex;
        gap: 0.5rem;
        align-items: center;
      }
      .tool-name {
        font-weight: 600;
        color: var(--fg);
      }
      .tool-status {
        font-size: 0.68rem;
        padding: 0.1rem 0.4rem;
        border-radius: 3px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }
      .tool-status.pending,
      .tool-status.in_progress {
        background: rgba(255, 213, 74, 0.2);
        color: var(--accent);
      }
      .tool-status.completed {
        background: rgba(102, 204, 102, 0.18);
        color: var(--success);
      }
      .tool-status.failed,
      .tool-status.error {
        background: rgba(255, 102, 102, 0.18);
        color: var(--danger);
      }
      .tool-locations {
        color: var(--fg-dim);
        font-size: 0.72rem;
        margin-top: 0.25rem;
      }
      .tool-content {
        margin-top: 0.35rem;
        background: #0a0a0a;
        border: 1px solid var(--border);
        border-radius: 3px;
        padding: 0.4rem 0.5rem;
        font-size: 0.72rem;
        max-height: 200px;
        overflow-y: auto;
        white-space: pre-wrap;
        word-break: break-word;
      }
      .tool-content[hidden] {
        display: none;
      }
      .tool-toggle {
        background: transparent;
        color: var(--fg-dim);
        border: none;
        font-size: 0.7rem;
        cursor: pointer;
        padding: 0 0.2rem;
        margin-left: auto;
      }
      .projects {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 0.75rem;
        margin-top: 0.5rem;
      }
      .project-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 0.75rem 1rem;
        display: grid;
        gap: 0.45rem;
      }
      /* v0.30.0 — starred cards get a subtle accent ring so the pinned
         group is recognizable at a glance even while scrolling. */
      .project-card.starred { border-color: var(--accent); }
      .project-name {
        font-size: 0.8125rem;
        color: var(--accent);
        word-break: break-all;
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }
      .project-star {
        background: transparent;
        border: none;
        cursor: pointer;
        font-size: 0.95rem;
        line-height: 1;
        color: var(--fg-dim);
        padding: 0 0.1rem;
      }
      .project-star:hover { color: var(--accent); }
      .project-star.is-starred { color: #ffd54a; }
      .project-card.starred .project-name code { color: var(--accent); }
      .project-row {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 0.5rem;
        font-size: 0.75rem;
        font-variant-numeric: tabular-nums;
      }
      .project-cost {
        color: var(--fg);
        font-weight: 600;
        font-size: 0.9rem;
      }
      .project-meta { color: var(--fg-dim); }
      .project-tokens { color: var(--fg-dim); }
      .project-tokens code {
        color: var(--fg);
        background: transparent;
        padding: 0;
      }
      .project-lines .added { color: #70d99c; }
      .project-lines .removed { color: #ff7878; }
      /* v0.29.0 — efficiency bar (yellow → green → red by tok/ln tier). */
      .project-eff {
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }
      .project-eff-bar {
        flex: 1;
        height: 6px;
        background: rgba(255,255,255,0.08);
        border-radius: 3px;
        overflow: hidden;
      }
      .project-eff-fill {
        height: 100%;
        border-radius: 3px;
      }
      .project-eff-fill.tier-good { background: #70d99c; }
      .project-eff-fill.tier-mid  { background: #ffd54a; }
      .project-eff-fill.tier-bad  { background: #ff7878; }
      .project-eff-label {
        font-size: 0.7rem;
        color: var(--fg-dim);
        white-space: nowrap;
      }
      /* Single-color sparkline (back-compat, kept for the flat cost line). */
      .sparkline {
        display: block;
        width: 100%;
        height: 24px;
      }
      .sparkline path {
        fill: none;
        stroke: var(--accent);
        stroke-width: 1.5;
      }
      .sparkline .area {
        fill: var(--accent);
        opacity: 0.12;
        stroke: none;
      }
      /* v0.29.0 — stacked sparkline (opus violet / sonnet blue / haiku green / other grey). */
      .sparkline-stack { display: block; width: 100%; height: 24px; }
      .sparkline-stack .lyr-opus   { fill: rgba(197,151,255,0.85); }
      .sparkline-stack .lyr-sonnet { fill: rgba(105,184,255,0.85); }
      .sparkline-stack .lyr-haiku  { fill: rgba(112,217,156,0.85); }
      .sparkline-stack .lyr-other  { fill: rgba(180,180,180,0.55); }
      .rate-limits {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 0.75rem 1rem;
        margin-top: 0.5rem;
        font-size: 0.8125rem;
      }
      .rate-meta {
        color: var(--fg-dim);
        font-size: 0.75rem;
        margin-bottom: 0.5rem;
      }
      .rate-bar {
        display: grid;
        grid-template-columns: 8rem 1fr 3rem;
        gap: 0.5rem;
        align-items: center;
        margin: 0.4rem 0;
      }
      .rate-bar-label {
        color: var(--fg);
      }
      .rate-bar-track {
        background: rgba(255, 255, 255, 0.06);
        height: 6px;
        border-radius: 3px;
        overflow: hidden;
      }
      .rate-bar-fill {
        height: 100%;
        background: var(--accent);
      }
      .rate-bar-fill.warn {
        background: #ffaa00;
      }
      .rate-bar-fill.danger {
        background: var(--danger);
      }
      .rate-bar-value {
        text-align: right;
        font-variant-numeric: tabular-nums;
        color: var(--fg-dim);
      }
      .rate-raw {
        margin-top: 0.5rem;
        font-size: 0.7rem;
        color: var(--fg-dim);
        max-height: 160px;
        overflow-y: auto;
        white-space: pre-wrap;
        word-break: break-all;
      }
      .heatmap-tabs {
        display: flex;
        gap: 0.4rem;
        margin: 0.5rem 0;
        flex-wrap: wrap;
      }
      .heatmap-tabs button {
        background: transparent;
        color: var(--fg-dim);
        border: 1px solid var(--border);
        font-size: 0.75rem;
        padding: 0.3rem 0.7rem;
        cursor: pointer;
      }
      .heatmap-tabs button.active {
        background: var(--accent);
        color: #000;
        border-color: var(--accent);
        font-weight: 600;
      }
      .heatmap {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 0.75rem;
        overflow-x: auto;
      }
      .heatmap-grid {
        display: grid;
        grid-template-rows: repeat(7, 1fr);
        grid-auto-flow: column;
        grid-auto-columns: 11px;
        gap: 2px;
      }
      .heatmap-cell {
        width: 11px;
        height: 11px;
        background: rgba(255, 213, 74, 0);
        border-radius: 2px;
      }
      .heatmap-cell.lvl-1 { background: rgba(255, 213, 74, 0.18); }
      .heatmap-cell.lvl-2 { background: rgba(255, 213, 74, 0.38); }
      .heatmap-cell.lvl-3 { background: rgba(255, 213, 74, 0.62); }
      .heatmap-cell.lvl-4 { background: rgba(255, 213, 74, 0.95); }
      .heatmap-cell.empty { background: rgba(255, 255, 255, 0.04); }

      /* v0.28.0 — CCMeter-style 4-up heatmap row. Each card uses its own
         accent so Input/Output/Lines/Cost are distinguishable at a glance. */
      .heatmap-quad {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0.6rem;
        margin: 0.5rem 0 1rem;
      }
      @media (max-width: 1100px) {
        .heatmap-quad { grid-template-columns: repeat(2, 1fr); }
      }
      @media (max-width: 600px) {
        .heatmap-quad { grid-template-columns: 1fr; }
      }
      .heatmap-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 0.5rem 0.6rem 0.6rem;
        overflow-x: auto;
      }
      .heatmap-card-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 0.5rem;
        margin-bottom: 0.4rem;
      }
      .heatmap-card-title {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--fg-dim);
      }
      .heatmap-card-total {
        font-size: 0.95rem;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
      }
      .heatmap-card-grid {
        display: grid;
        grid-template-rows: repeat(7, 1fr);
        grid-auto-flow: column;
        grid-auto-columns: 9px;
        gap: 2px;
      }
      .heatmap-card-grid .heatmap-cell { width: 9px; height: 9px; }
      /* Per-metric tints — Input=blue, Output=violet, Lines=amber, Cost=green. */
      .heatmap-card[data-metric="inputTokens"]   .heatmap-card-total { color: #69b8ff; }
      .heatmap-card[data-metric="inputTokens"]   .heatmap-cell.lvl-1 { background: rgba(105,184,255,0.18); }
      .heatmap-card[data-metric="inputTokens"]   .heatmap-cell.lvl-2 { background: rgba(105,184,255,0.38); }
      .heatmap-card[data-metric="inputTokens"]   .heatmap-cell.lvl-3 { background: rgba(105,184,255,0.62); }
      .heatmap-card[data-metric="inputTokens"]   .heatmap-cell.lvl-4 { background: rgba(105,184,255,0.95); }
      .heatmap-card[data-metric="outputTokens"]  .heatmap-card-total { color: #c597ff; }
      .heatmap-card[data-metric="outputTokens"]  .heatmap-cell.lvl-1 { background: rgba(197,151,255,0.18); }
      .heatmap-card[data-metric="outputTokens"]  .heatmap-cell.lvl-2 { background: rgba(197,151,255,0.38); }
      .heatmap-card[data-metric="outputTokens"]  .heatmap-cell.lvl-3 { background: rgba(197,151,255,0.62); }
      .heatmap-card[data-metric="outputTokens"]  .heatmap-cell.lvl-4 { background: rgba(197,151,255,0.95); }
      .heatmap-card[data-metric="linesChanged"]  .heatmap-card-total { color: #ffb84d; }
      .heatmap-card[data-metric="linesChanged"]  .heatmap-cell.lvl-1 { background: rgba(255,184,77,0.18); }
      .heatmap-card[data-metric="linesChanged"]  .heatmap-cell.lvl-2 { background: rgba(255,184,77,0.38); }
      .heatmap-card[data-metric="linesChanged"]  .heatmap-cell.lvl-3 { background: rgba(255,184,77,0.62); }
      .heatmap-card[data-metric="linesChanged"]  .heatmap-cell.lvl-4 { background: rgba(255,184,77,0.95); }
      .heatmap-card[data-metric="cost"]          .heatmap-card-total { color: #70d99c; }
      .heatmap-card[data-metric="cost"]          .heatmap-cell.lvl-1 { background: rgba(112,217,156,0.18); }
      .heatmap-card[data-metric="cost"]          .heatmap-cell.lvl-2 { background: rgba(112,217,156,0.38); }
      .heatmap-card[data-metric="cost"]          .heatmap-cell.lvl-3 { background: rgba(112,217,156,0.62); }
      .heatmap-card[data-metric="cost"]          .heatmap-cell.lvl-4 { background: rgba(112,217,156,0.95); }
      .heatmap-legend {
        display: flex;
        gap: 0.4rem;
        align-items: center;
        margin-top: 0.5rem;
        font-size: 0.7rem;
        color: var(--fg-dim);
      }
      .heatmap-legend .swatch {
        width: 11px;
        height: 11px;
        border-radius: 2px;
      }
    </style>
  </head>
  <body>
    <h1>★ {title}</h1>
    <p class="tagline">{tagline}.</p>

    <section id="auth-pane">
      <p class="muted">
        Enter the bearer token configured via <code>POLARIS_AUTH_TOKEN</code>. Stored
        in your browser's localStorage; never sent anywhere except this Polaris
        instance.
      </p>
      <form id="token-form" class="token-form">
        <input
          type="password"
          id="token-input"
          autocomplete="off"
          placeholder="POLARIS_AUTH_TOKEN"
          required
        />
        <button type="submit">Unlock</button>
      </form>
    </section>

    <section id="dashboard" hidden>
      <div class="tabs" role="tablist">
        <button data-tab="metrics" class="active">Metrics</button>
        <button data-tab="sessions">Sessions<span id="sessions-badge" class="tab-badge" hidden>0</span></button>
        <button id="logout" class="logout">Logout</button>
      </div>

      <div id="tab-metrics">
        <div class="range-tabs" role="tablist">
          <button data-range="1h">1h</button>
          <button data-range="12h">12h</button>
          <button data-range="today" class="active">Today</button>
          <button data-range="7d">7 days</button>
          <button data-range="30d">30 days</button>
          <button data-range="all">All</button>
        </div>
        <div id="kpis" class="kpis"></div>
        <div id="per-model" class="per-model"></div>
        <p class="muted" id="range-meta"></p>

        <h2>Activity (last 180 days)</h2>
        <div class="heatmap-quad">
          <div class="heatmap-card" data-metric="inputTokens">
            <div class="heatmap-card-head">
              <span class="heatmap-card-title">Input</span>
              <span class="heatmap-card-total" data-total>—</span>
            </div>
            <div class="heatmap-card-grid"></div>
          </div>
          <div class="heatmap-card" data-metric="outputTokens">
            <div class="heatmap-card-head">
              <span class="heatmap-card-title">Output</span>
              <span class="heatmap-card-total" data-total>—</span>
            </div>
            <div class="heatmap-card-grid"></div>
          </div>
          <div class="heatmap-card" data-metric="linesChanged">
            <div class="heatmap-card-head">
              <span class="heatmap-card-title">Lines</span>
              <span class="heatmap-card-total" data-total>—</span>
            </div>
            <div class="heatmap-card-grid"></div>
          </div>
          <div class="heatmap-card" data-metric="cost">
            <div class="heatmap-card-head">
              <span class="heatmap-card-title">Cost</span>
              <span class="heatmap-card-total" data-total>—</span>
            </div>
            <div class="heatmap-card-grid"></div>
          </div>
        </div>

        <h2>Projects (last 30 days)</h2>
        <div id="projects" class="projects"></div>

        <h2>Rate limits</h2>
        <div id="rate-limits" class="rate-limits"></div>
      </div>

      <div id="tab-sessions" hidden>
        <h2>New session</h2>
        <form id="new-session-form" class="new-session">
          <input
            type="text"
            id="new-session-cwd"
            placeholder="Working directory (absolute path)"
            list="cwd-history"
            autocomplete="off"
            required
          />
          <datalist id="cwd-history"></datalist>
          <button type="submit">Create</button>
        </form>
        <h2>Active sessions</h2>
        <div id="sessions-list"></div>
        <div id="session-detail" hidden>
          <h2>Selected session</h2>
          <form id="prompt-form" class="prompt-form">
            <textarea
              id="prompt-text"
              placeholder="Type a prompt — Enter to send, Shift+Enter for newline, Ctrl+L to clear log, Esc to blur"
              required
              rows="2"
            ></textarea>
            <div class="row">
              <button type="submit">Send prompt</button>
              <button type="button" id="delete-session" class="danger">Delete session</button>
            </div>
          </form>
          <div id="response-pane" class="response-pane muted">No prompt sent yet.</div>
        </div>
      </div>
    </section>

    <script is:inline>
      const TOKEN_KEY = "polaris.token";
      const getToken = () => localStorage.getItem(TOKEN_KEY);
      const setToken = (t) => localStorage.setItem(TOKEN_KEY, t);
      const clearToken = () => localStorage.removeItem(TOKEN_KEY);

      // v0.30.0 — starred projects pin to the top of the grid. Persisted in
      // localStorage so the user's choices survive reloads but never leave
      // the browser (matches CCMeter's local-only star concept).
      const STARRED_KEY = "polaris.starredProjects";
      function getStarred() {
        try {
          const raw = localStorage.getItem(STARRED_KEY);
          if (!raw) return new Set();
          const arr = JSON.parse(raw);
          return new Set(Array.isArray(arr) ? arr : []);
        } catch {
          return new Set();
        }
      }
      function setStarred(set) {
        localStorage.setItem(STARRED_KEY, JSON.stringify([...set]));
      }
      function toggleStarred(name) {
        const set = getStarred();
        if (set.has(name)) set.delete(name);
        else set.add(name);
        setStarred(set);
        return set;
      }

      const formatUsd = (n) => {
        if (!Number.isFinite(n) || n <= 0) return "$0";
        if (n >= 1000) return "$" + (n / 1000).toFixed(1) + "K";
        if (n >= 100) return "$" + n.toFixed(0);
        if (n >= 1) return "$" + n.toFixed(2);
        return "¢" + (n * 100).toFixed(0);
      };
      const formatTokens = (n) => {
        if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + "M";
        if (n >= 1_000) return (n / 1_000).toFixed(1) + "K";
        return String(n);
      };
      const escape = (s) =>
        String(s).replace(/[&<>"']/g, (c) => ({
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;",
        })[c]);

      const $ = (id) => document.getElementById(id);
      const authHeader = () => ({ Authorization: "Bearer " + getToken() });

      const showAuth = () => {
        $("auth-pane").hidden = false;
        $("dashboard").hidden = true;
      };
      const showDashboard = () => {
        $("auth-pane").hidden = true;
        $("dashboard").hidden = false;
        startSessionsPoll();
      };

      async function apiFetch(path, init = {}) {
        const res = await fetch(path, {
          ...init,
          headers: {
            "content-type": "application/json",
            ...authHeader(),
            ...(init.headers || {}),
          },
        });
        if (res.status === 401) {
          clearToken();
          showAuth();
          throw new Error("Token rejected");
        }
        return res;
      }

      // ── Metrics tab ──────────────────────────────────────────────────────
      async function fetchMetrics(range) {
        const res = await apiFetch("/v1/metrics?range=" + encodeURIComponent(range));
        if (!res.ok) throw new Error("HTTP " + res.status);
        return res.json();
      }
      function efficiency(outputTokens, linesAdded) {
        if (!linesAdded || linesAdded <= 0) return "—";
        const ratio = outputTokens / linesAdded;
        if (ratio >= 1000) return (ratio / 1000).toFixed(1) + "K";
        return ratio.toFixed(0);
      }
      // v0.25.0: percent-delta vs previous period. Returns a small HTML chip
      // like <span class="delta up">+12%</span>. Skipped when previous is
      // null/zero (no meaningful comparison).
      function deltaChip(curr, prev) {
        if (typeof prev !== "number" || prev <= 0) return "";
        const ratio = curr / prev - 1;
        const pct = ratio * 100;
        const sign = pct >= 0 ? "+" : "";
        // Up/down here is about value direction; the CSS picks a color but
        // intentionally doesn't moralize ("+12% cost" = bad, "+12% lines" =
        // good is context-dependent).
        const dir = pct >= 0 ? "up" : "down";
        const label = `${sign}${pct.toFixed(0)}%`;
        return ` <span class="delta ${dir}">${label}</span>`;
      }
      function renderMetrics(data) {
        const prev = data.previous?.totals ?? null;
        const t = data.totals;
        // v0.28.0 — CCMeter parity: lead with Cost / Streak / Active / Avg/day
        // / Efficiency, then expand into the detail KPIs. Streak/Active/Avg
        // are server-computed in v0.28.0; older clients calling the same
        // server with an older UI just ignore them.
        const activeOf = (a, w) => (w > 0 ? `${a}/${w}` : String(a));
        const kpis = [
          {
            label: "Total cost",
            value: formatUsd(t.costUsd),
            delta: deltaChip(t.costUsd, prev?.costUsd ?? null),
          },
          {
            label: "Streak",
            value: (t.streak ?? 0) + (t.streak === 1 ? " day" : " days"),
            delta: "",
          },
          {
            label: "Active days",
            value: activeOf(t.activeDays ?? 0, t.windowDays ?? 0),
            delta: "",
          },
          {
            label: "Avg/day (out)",
            value: formatTokens(Math.round(t.avgOutputPerActiveDay ?? 0)),
            delta: "",
          },
          {
            label: "Tokens / line",
            value: efficiency(t.outputTokens, t.linesAdded ?? 0),
            delta: "",
          },
          {
            label: "Events",
            value: String(t.events),
            delta: deltaChip(t.events, prev?.events ?? null),
          },
          {
            label: "Input tokens",
            value: formatTokens(t.inputTokens),
            delta: deltaChip(t.inputTokens, prev?.inputTokens ?? null),
          },
          {
            label: "Output tokens",
            value: formatTokens(t.outputTokens),
            delta: deltaChip(t.outputTokens, prev?.outputTokens ?? null),
          },
          {
            label: "Cache reads",
            value: formatTokens(t.cacheReadTokens),
            delta: deltaChip(t.cacheReadTokens, prev?.cacheReadTokens ?? null),
          },
          {
            label: "Lines added",
            value: formatTokens(t.linesAdded ?? 0),
            delta: deltaChip(t.linesAdded ?? 0, prev?.linesAdded ?? null),
          },
          {
            label: "Lines removed",
            value: formatTokens(t.linesRemoved ?? 0),
            delta: deltaChip(t.linesRemoved ?? 0, prev?.linesRemoved ?? null),
          },
        ];
        $("kpis").innerHTML = kpis
          .map(
            (k) =>
              '<div class="kpi"><div class="kpi-label">' +
              k.label +
              '</div><div class="kpi-value">' +
              k.value +
              (k.delta ?? "") +
              "</div></div>",
          )
          .join("");
        const header =
          '<div class="model-row header"><div>Model</div><div>Events</div><div>Tokens</div><div>Cost</div></div>';
        const rows = data.perModel
          .map(
            (m) =>
              '<div class="model-row"><div>' +
              escape(m.model) +
              "</div><div>" +
              m.events +
              " events</div><div>" +
              formatTokens(m.inputTokens + m.outputTokens) +
              " tok</div><div>" +
              formatUsd(m.costUsd) +
              "</div></div>",
          )
          .join("");
        $("per-model").innerHTML =
          rows.length > 0 ? header + rows : '<p class="muted">No events in this range yet.</p>';
        $("range-meta").textContent =
          "Range: " +
          data.range +
          " · " +
          new Date(data.fromMs).toISOString() +
          " → " +
          new Date(data.toMs).toISOString();
      }
      async function loadMetrics(range) {
        try {
          renderMetrics(await fetchMetrics(range));
        } catch (e) {
          $("kpis").innerHTML = '<div class="error">Failed to load: ' + escape(e.message) + "</div>";
          $("per-model").innerHTML = "";
        }
      }

      // ── Projects (sparkline cards) ───────────────────────────────────────
      function sparklineSvg(values) {
        if (!Array.isArray(values) || values.length === 0) return "";
        const w = 260;
        const h = 32;
        const max = Math.max(0.0001, ...values);
        const step = values.length > 1 ? w / (values.length - 1) : 0;
        const pts = values.map((v, i) => {
          const x = i * step;
          const y = h - (v / max) * (h - 2) - 1;
          return x.toFixed(1) + "," + y.toFixed(1);
        });
        const linePath = "M" + pts.join(" L");
        const areaPath = linePath + " L" + w.toFixed(1) + "," + h + " L0," + h + " Z";
        return (
          '<svg class="sparkline" viewBox="0 0 ' + w + " " + h +
          '" preserveAspectRatio="none">' +
          '<path class="area" d="' + areaPath + '"/>' +
          '<path d="' + linePath + '"/>' +
          "</svg>"
        );
      }
      async function fetchProjects(days = 30) {
        const res = await apiFetch("/v1/projects?days=" + days);
        if (!res.ok) throw new Error("HTTP " + res.status);
        return res.json();
      }
      // v0.29.0 — render duration as CCMeter does ("Xh Ym" / "Xm Ys" / "Xs").
      function formatActiveDuration(ms) {
        if (!Number.isFinite(ms) || ms <= 0) return "—";
        const totalSec = Math.round(ms / 1000);
        const h = Math.floor(totalSec / 3600);
        const m = Math.floor((totalSec % 3600) / 60);
        const s = totalSec % 60;
        if (h > 0) return h + "h" + (m > 0 ? m + "m" : "");
        if (m > 0) return m + "m" + (s > 0 && m < 10 ? s + "s" : "");
        return s + "s";
      }
      // CCMeter colours its efficiency bar green / yellow / red based on
      // tokens-per-line tiers. Lower = more concise output → greener.
      function efficiencyTier(tokPerLine) {
        if (tokPerLine <= 0) return { cls: "tier-mid", pct: 0 };
        if (tokPerLine <= 80) return { cls: "tier-good", pct: 30 };
        if (tokPerLine <= 200) return { cls: "tier-mid", pct: 60 };
        return { cls: "tier-bad", pct: 100 };
      }
      // v0.29.0 — stacked sparkline that shows daily output tokens per
      // model family. Stacks opus over sonnet over haiku, with "other"
      // as a thin grey base.
      function stackedSparkline(byFamily) {
        if (!byFamily) return "";
        const families = ["other", "haiku", "sonnet", "opus"];
        const series = families.map((f) => byFamily[f] ?? []);
        const days = Math.max(0, ...series.map((s) => s.length));
        if (days === 0) return "";
        const w = 260;
        const h = 24;
        const totals = Array(days).fill(0);
        for (const s of series) {
          for (let i = 0; i < days; i++) totals[i] += s[i] ?? 0;
        }
        const max = Math.max(0.0001, ...totals);
        const step = days > 1 ? w / (days - 1) : 0;
        // Build cumulative top edges per layer, bottom-up.
        const stacks = [];
        const running = Array(days).fill(0);
        for (const layer of series) {
          const tops = [];
          for (let i = 0; i < days; i++) {
            running[i] += layer[i] ?? 0;
            tops.push(running[i]);
          }
          stacks.push(tops.slice());
        }
        // Build polygons bottom-up so the lowest layer paints first.
        let lastBottom = Array(days).fill(0);
        const paths = [];
        for (let li = 0; li < stacks.length; li++) {
          const top = stacks[li];
          const bot = lastBottom;
          const cls = "lyr-" + families[li];
          const pts = [];
          for (let i = 0; i < days; i++) {
            const x = i * step;
            const y = h - ((top[i] ?? 0) / max) * (h - 1);
            pts.push(x.toFixed(1) + "," + y.toFixed(1));
          }
          for (let i = days - 1; i >= 0; i--) {
            const x = i * step;
            const y = h - ((bot[i] ?? 0) / max) * (h - 1);
            pts.push(x.toFixed(1) + "," + y.toFixed(1));
          }
          paths.push('<polygon class="' + cls + '" points="' + pts.join(" ") + '"/>');
          lastBottom = top.slice();
        }
        return (
          '<svg class="sparkline-stack" viewBox="0 0 ' + w + " " + h +
          '" preserveAspectRatio="none">' + paths.join("") + "</svg>"
        );
      }
      function renderProjects(data) {
        if (!data.projects || data.projects.length === 0) {
          $("projects").innerHTML = '<p class="muted">No project data in the last 30 days.</p>';
          return;
        }
        // v0.30.0 — starred projects come first, then unstarred. Within each
        // group the existing cost-desc order coming from the API is preserved.
        const starred = getStarred();
        const ordered = data.projects.slice().sort((a, b) => {
          const aStar = starred.has(a.name);
          const bStar = starred.has(b.name);
          if (aStar !== bStar) return aStar ? -1 : 1;
          return (b.costUsd ?? 0) - (a.costUsd ?? 0);
        });
        $("projects").innerHTML = ordered
          .map((p) => {
            const tpl = p.outputPerLine ?? 0;
            const eff = efficiencyTier(tpl);
            const linesAdded = p.linesAdded ?? 0;
            const linesRemoved = p.linesRemoved ?? 0;
            const isStarred = starred.has(p.name);
            const starIcon = isStarred ? "★" : "☆";
            const linesRow =
              linesAdded > 0 || linesRemoved > 0
                ? '<div class="project-row project-lines">' +
                  '<span><span class="added">+' + formatTokens(linesAdded) +
                  '</span> <span class="removed">-' + formatTokens(linesRemoved) + "</span></span>" +
                  '<span class="project-meta">' +
                  p.sessions + " sess · " + p.events + " ev</span>" +
                  "</div>"
                : '<div class="project-row"><span class="project-meta">' +
                  p.sessions + " sess · " + p.events + " ev</span></div>";
            const tplLabel = tpl > 0 ? Math.round(tpl) + " tok/ln" : "no lines yet";
            return (
              '<div class="project-card' + (isStarred ? " starred" : "") + '">' +
              '<div class="project-name">' +
              '<button type="button" class="project-star' + (isStarred ? " is-starred" : "") +
              '" data-star="' + escape(p.name) + '" title="' +
              (isStarred ? "Unstar" : "Star") + '">' + starIcon + "</button>" +
              "<span>" + escape(p.name) + "</span>" +
              "</div>" +
              '<div class="project-row">' +
              '<span class="project-cost">' + formatUsd(p.costUsd) + "</span>" +
              '<span class="project-meta">⏱ ' +
              escape(formatActiveDuration(p.activeMs ?? 0)) +
              "</span>" +
              "</div>" +
              '<div class="project-row project-tokens">' +
              "in <code>" + formatTokens(p.inputTokens) + "</code> · " +
              "out <code>" + formatTokens(p.outputTokens) + "</code> · " +
              "cache <code>" + formatTokens(p.cacheReadTokens) + "</code>" +
              "</div>" +
              linesRow +
              '<div class="project-eff">' +
              '<div class="project-eff-bar"><div class="project-eff-fill ' +
              eff.cls + '" style="width:' + eff.pct + '%"></div></div>' +
              '<span class="project-eff-label">' + escape(tplLabel) + "</span>" +
              "</div>" +
              (stackedSparkline(p.dailyByFamily) || sparklineSvg(p.dailyCostUsd)) +
              "</div>"
            );
          })
          .join("");
        // v0.30.0 — wire the star toggle. One delegated listener per render
        // is cheaper than per-card listeners and keeps the markup clean.
        $("projects").querySelectorAll(".project-star[data-star]").forEach((btn) => {
          btn.addEventListener("click", (ev) => {
            ev.stopPropagation();
            const name = btn.getAttribute("data-star");
            if (!name) return;
            toggleStarred(name);
            if (lastProjectsData) renderProjects(lastProjectsData);
          });
        });
      }
      // Last successful /v1/projects payload, so toggling a star re-renders
      // without hitting the network.
      let lastProjectsData = null;
      async function loadProjects() {
        try {
          const data = await fetchProjects(30);
          lastProjectsData = data;
          renderProjects(data);
        } catch (e) {
          $("projects").innerHTML =
            '<div class="error">Failed to load projects: ' + escape(e.message) + "</div>";
        }
      }

      // ── Activity heatmaps (v0.28.0: 4-up CCMeter-style) ──────────────────
      // The four metrics rendered in the dashboard's headline row. Each has
      // its own card, accent colour, and total label.
      const HEATMAP_METRICS = ["inputTokens", "outputTokens", "linesChanged", "cost"];
      function heatmapLevel(value, thresholds) {
        if (value <= 0) return 0;
        if (value <= thresholds[0]) return 1;
        if (value <= thresholds[1]) return 2;
        if (value <= thresholds[2]) return 3;
        return 4;
      }
      function quartileThresholds(values) {
        const nonZero = values.filter((v) => v > 0).sort((a, b) => a - b);
        if (nonZero.length === 0) return [0, 0, 0];
        const q = (p) => nonZero[Math.min(nonZero.length - 1, Math.floor(nonZero.length * p))];
        return [q(0.25), q(0.5), q(0.75)];
      }
      function formatHeatmapValue(metric, value) {
        if (metric === "cost") return formatUsd(value);
        if (metric === "inputTokens" || metric === "outputTokens") return formatTokens(value);
        if (metric === "linesChanged") return formatTokens(value) + " lines";
        if (metric === "sessions") return value + " sess";
        return value + " ev";
      }
      function renderHeatmapCard(card, data) {
        const grid = card.querySelector(".heatmap-card-grid");
        const totalEl = card.querySelector("[data-total]");
        if (!data?.dailyValues?.length) {
          grid.innerHTML = "";
          if (totalEl) totalEl.textContent = "—";
          return;
        }
        const total = data.dailyValues.reduce((a, b) => a + b, 0);
        if (totalEl) totalEl.textContent = formatHeatmapValue(data.metric, total);
        const thresholds = quartileThresholds(data.dailyValues);
        const cells = [];
        const dayMs = 24 * 60 * 60 * 1000;
        for (let i = 0; i < data.firstDayOfWeekUtc; i++) {
          cells.push('<div class="heatmap-cell empty"></div>');
        }
        for (let i = 0; i < data.dailyValues.length; i++) {
          const value = data.dailyValues[i];
          const lvl = heatmapLevel(value, thresholds);
          const date = new Date(data.fromMs + i * dayMs);
          const dateStr = date.toISOString().slice(0, 10);
          const cls = value <= 0 ? "empty" : "lvl-" + lvl;
          const title = dateStr + ": " + formatHeatmapValue(data.metric, value);
          cells.push(
            '<div class="heatmap-cell ' + cls + '" title="' + escape(title) + '"></div>',
          );
        }
        grid.innerHTML = cells.join("");
      }
      async function loadHeatmaps() {
        const cards = Array.from(document.querySelectorAll(".heatmap-card[data-metric]"));
        const results = await Promise.all(
          cards.map(async (card) => {
            const metric = card.getAttribute("data-metric");
            try {
              const res = await apiFetch(
                "/v1/heatmap?days=180&metric=" + encodeURIComponent(metric),
              );
              if (!res.ok) return { card, data: null };
              return { card, data: await res.json() };
            } catch {
              return { card, data: null };
            }
          }),
        );
        for (const { card, data } of results) renderHeatmapCard(card, data);
      }

      // ── Rate limits ──────────────────────────────────────────────────────
      function rateBar(label, utilization) {
        const raw = Number(utilization) || 0;
        // Anthropic's /api/oauth/usage returns utilization as 0-100. Some
        // CCMeter docs imply 0-1; accept both: anything > 1 is treated as
        // already-percent, anything <= 1 as a fraction.
        const normalized = raw > 1 ? raw / 100 : raw;
        const u = Math.max(0, Math.min(1, normalized));
        const pct = (u * 100).toFixed(0);
        const cls = u >= 0.9 ? "danger" : u >= 0.75 ? "warn" : "";
        return (
          '<div class="rate-bar"><div class="rate-bar-label">' +
          escape(label) +
          '</div><div class="rate-bar-track"><div class="rate-bar-fill ' +
          cls +
          '" style="width:' +
          pct +
          '%"></div></div><div class="rate-bar-value">' +
          pct +
          "%</div></div>"
        );
      }
      function prettyWindowLabel(key) {
        return key
          .replace(/_/g, " ")
          .replace(/\bfive\b/i, "5-hour")
          .replace(/\bseven day\b/i, "7-day")
          .replace(/\b\w/g, (c) => c.toUpperCase());
      }
      function renderRateLimits(data) {
        const pane = $("rate-limits");
        if (data.error) {
          pane.innerHTML =
            '<div class="rate-meta">Last poll: ' +
            new Date(data.tsMs).toISOString() +
            " · HTTP " +
            data.httpStatus +
            '</div><div class="error">' +
            escape(data.error) +
            "</div>";
          return;
        }
        const payload = data.payload || {};
        // Dynamically render every top-level field that looks like a usage
        // window (has a numeric `utilization`). Real Anthropic responses
        // include more windows than the CCMeter-documented three.
        const bars = [];
        for (const [key, value] of Object.entries(payload)) {
          if (
            value !== null &&
            typeof value === "object" &&
            "utilization" in value &&
            (typeof value.utilization === "number" ||
              typeof value.utilization === "string")
          ) {
            const num = Number(value.utilization);
            if (Number.isFinite(num) && num > 0) {
              bars.push(rateBar(prettyWindowLabel(key), num));
            }
          }
        }
        const meta =
          '<div class="rate-meta">Last poll: ' +
          new Date(data.tsMs).toISOString() +
          " · HTTP " +
          data.httpStatus +
          "</div>";
        if (bars.length > 0) {
          pane.innerHTML = meta + bars.join("");
          return;
        }
        // Unknown response shape — show raw JSON so we can iterate without code changes.
        pane.innerHTML =
          meta +
          '<div class="rate-raw">' +
          escape(JSON.stringify(payload, null, 2)) +
          "</div>";
      }
      async function loadRateLimits() {
        try {
          const res = await apiFetch("/v1/rate-limits");
          if (res.status === 503) {
            const body = await res.json();
            $("rate-limits").innerHTML =
              '<p class="muted">' +
              (body.configured
                ? "Waiting for first poll (every ~8 min)."
                : "OAuth credentials not found at ~/.claude/.credentials.json — rate-limit tracking is disabled.") +
              "</p>";
            return;
          }
          if (!res.ok) throw new Error("HTTP " + res.status);
          renderRateLimits(await res.json());
        } catch (e) {
          $("rate-limits").innerHTML =
            '<div class="error">Failed to load rate limits: ' + escape(e.message) + "</div>";
        }
      }

      // ── Sessions tab ─────────────────────────────────────────────────────
      // v0.6.0 ships the basic registry: list / create / prompt (sync) / delete.
      // Live SSE event stream + inline approval buttons land in v0.6.1; until
      // then the SessionManager auto-resolves nothing — a prompt that needs a
      // permission hangs until the per-approval 5-min timeout cancels it.
      let selectedSession = null;

      async function refreshSessions() {
        try {
          const res = await apiFetch("/v1/sessions");
          if (!res.ok) throw new Error("HTTP " + res.status);
          const { sessions } = await res.json();
          renderSessions(sessions);
          updateCwdHistory(sessions);
          updateApprovalBadge(sessions);
        } catch (e) {
          $("sessions-list").innerHTML =
            '<div class="error">Failed to load: ' + escape(e.message) + "</div>";
        }
      }
      // v0.20.0: badge on the Sessions tab + browser notification when ANY
      // session has a pending approval. Polled every 5s in the background.
      let lastApprovalCount = 0;
      function updateApprovalBadge(sessions) {
        const total = sessions.reduce(
          (n, s) => n + (Number(s.pendingApprovalsCount) || 0),
          0,
        );
        const badge = $("sessions-badge");
        if (total > 0) {
          badge.textContent = String(total);
          badge.hidden = false;
        } else {
          badge.hidden = true;
        }
        if (total > lastApprovalCount && total > 0) {
          notifyApprovalNeeded(total, sessions);
        }
        lastApprovalCount = total;
      }
      function notifyApprovalNeeded(total, sessions) {
        if (typeof Notification === "undefined") return;
        const fire = () => {
          const waiting = sessions
            .filter((s) => (s.pendingApprovalsCount || 0) > 0)
            .map((s) => s.cwd)
            .slice(0, 3)
            .join(", ");
          new Notification("Polaris — approval needed", {
            body:
              total +
              " session" +
              (total > 1 ? "s" : "") +
              " waiting" +
              (waiting ? " · " + waiting : ""),
            tag: "polaris-approval",
          });
        };
        if (Notification.permission === "granted") fire();
        else if (Notification.permission !== "denied") {
          Notification.requestPermission().then((p) => {
            if (p === "granted") fire();
          });
        }
      }
      // Background poll: only when the dashboard is unlocked. 5s feels
      // responsive without hammering the server (the endpoint is cheap).
      let sessionsPollHandle = null;
      function startSessionsPoll() {
        if (sessionsPollHandle !== null) return;
        sessionsPollHandle = setInterval(() => {
          refreshSessions().catch(() => {});
        }, 5000);
      }
      function stopSessionsPoll() {
        if (sessionsPollHandle === null) return;
        clearInterval(sessionsPollHandle);
        sessionsPollHandle = null;
      }
      function updateCwdHistory(sessions) {
        // v0.19.0: populate datalist with unique cwds from past + live
        // sessions (most-recent first). Browser auto-suggests as the user
        // types a prefix.
        const seen = new Set();
        const ordered = [];
        for (const s of sessions) {
          if (typeof s.cwd === "string" && !seen.has(s.cwd)) {
            seen.add(s.cwd);
            ordered.push(s.cwd);
          }
        }
        const dl = $("cwd-history");
        if (dl)
          dl.innerHTML = ordered
            .slice(0, 20)
            .map((cwd) => '<option value="' + escape(cwd) + '"></option>')
            .join("");
      }
      function summariseList(arr, max = 3) {
        if (!Array.isArray(arr) || arr.length === 0) return "";
        const shown = arr.slice(0, max).map(escape).join(", ");
        return arr.length > max ? shown + ", …" : shown;
      }
      function settingsBadges(s) {
        const cfg = s.settings;
        if (!cfg) return "";
        // Line 1: detected files (memory + settings).
        const files = [];
        if (cfg.claudeMdDetected) files.push("CLAUDE.md");
        if (cfg.agentsMdDetected) files.push("AGENTS.md");
        if (cfg.claudeSettingsDetected) files.push("settings.json");
        if (cfg.claudeSettingsLocalDetected) files.push("settings.local.json");
        if (Array.isArray(cfg.mcpServers) && cfg.mcpServers.length > 0) {
          files.push(`.mcp.json (${cfg.mcpServers.length}: ${summariseList(cfg.mcpServers)})`);
        }
        // Line 2: wired-up Claude Code extensions.
        const ext = [];
        if (cfg.commands?.length) ext.push(`${cfg.commands.length} commands`);
        if (cfg.agents?.length) ext.push(`${cfg.agents.length} agents`);
        if (cfg.skills?.length) ext.push(`${cfg.skills.length} skills`);
        if (cfg.outputStyles?.length) ext.push(`${cfg.outputStyles.length} output-styles`);
        // Line 3: resolved settings summary (model + permissions).
        const resolved = cfg.resolvedSettings;
        const settingsLine = [];
        if (resolved?.model) settingsLine.push(`model: <code>${escape(resolved.model)}</code>`);
        if (resolved?.outputStyle) settingsLine.push(`style: ${escape(resolved.outputStyle)}`);
        if (resolved && (resolved.permissionsAllow > 0 || resolved.permissionsDeny > 0)) {
          settingsLine.push(
            `permissions: ${resolved.permissionsAllow} allow · ${resolved.permissionsDeny} deny`,
          );
        }
        if (resolved?.hookEvents?.length) {
          settingsLine.push(`hooks: ${summariseList(resolved.hookEvents)}`);
        }
        if (resolved?.apiKeyHelperSet) settingsLine.push("apiKeyHelper");
        if (resolved?.envSet) settingsLine.push("env override");
        const lines = [];
        if (files.length) lines.push(`<div class="session-settings">loaded: ${files.join(" · ")}</div>`);
        if (ext.length) lines.push(`<div class="session-settings">${ext.join(" · ")}</div>`);
        if (settingsLine.length)
          lines.push(`<div class="session-settings">${settingsLine.join(" · ")}</div>`);
        if (Array.isArray(cfg.warnings) && cfg.warnings.length > 0) {
          lines.push(
            `<div class="session-settings warning">⚠ ${cfg.warnings.length} warning${cfg.warnings.length > 1 ? "s" : ""}</div>`,
          );
        }
        return lines.join("");
      }
      function renderSessions(sessions) {
        if (!sessions.length) {
          $("sessions-list").innerHTML = '<p class="muted">No active sessions.</p>';
          return;
        }
        $("sessions-list").innerHTML = sessions
          .map((s) => {
            const isClosed = s.status === "closed";
            const cls = [
              "session-card",
              s.id === selectedSession ? "selected" : "",
              s.pendingApprovalsCount > 0 ? "needs-approval" : "",
              isClosed ? "ended" : "",
