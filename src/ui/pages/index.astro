        entry.name.textContent = title;
        const st = merged.status || "pending";
        entry.status.className = "tool-status " + st;
        entry.status.textContent = st;
        const locs = Array.isArray(merged.locations) ? merged.locations : [];
        if (locs.length > 0) {
