              '<div class="' +
              cls +
              '" data-session-id="' +
              escape(s.id) +
              '"><div class="session-header"><span class="session-cwd">' +
              escape(s.cwd) +
              '</span><span class="session-id">' +
              escape(s.id.slice(0, 12)) +
              " · " +
              escape(s.status) +
              "</span></div>" +
              settingsBadges(s) +
              resumeBtn +
              "</div>"
