        }
        appendLog("approval", describeApproval(event.approval), { at: event.at, actions });
      }
      async function submitApproval(approvalId, optionId, actionsEl) {
        for (const btn of actionsEl.querySelectorAll("button")) btn.disabled = true;
        try {
          const res = await apiFetch(
            "/v1/sessions/" + encodeURIComponent(selectedSession) +
              "/approvals/" + encodeURIComponent(approvalId),
            { method: "POST", body: JSON.stringify({ outcome: "selected", optionId }) },
          );
          if (!res.ok) throw new Error("HTTP " + res.status);
          actionsEl.textContent = "responded: " + optionId;
        } catch (e) {
          appendLog("error", "Approval failed: " + e.message, null);
          for (const btn of actionsEl.querySelectorAll("button")) btn.disabled = false;
        }
      }
      function handleSseEvent(event) {
        if (event.type === "approval-request") {
          finalizeAssistantEntry();
          renderApproval(event);
          return;
        }
        if (event.type === "session-closed") {
          finalizeAssistantEntry();
          appendLog("closed", "session closed", { at: event.at });
          return;
        }
        if (event.type !== "update") return;
        const payload = event.payload || {};
        const p = payload.params || {};
        const kind = p.kind || payload.kind;
        if (kind === "agent_message_chunk" || kind === "agent_message") {
          const text = typeof p.content === "string"
            ? p.content
            : extractToolText(p.content) ?? p.text ?? "";
          if (text) renderAssistantChunk(text, event.at);
          return;
        }
        if (kind === "agent_thought_chunk" || kind === "thinking") {
          finalizeAssistantEntry();
          const text = typeof p.content === "string"
            ? p.content
            : extractToolText(p.content) ?? p.text ?? "";
          renderThinkingChunk(text || "thinking…", event.at, p.thoughtId || "primary");
          return;
        }
        if (kind === "tool_call" || kind === "tool_call_update") {
          finalizeAssistantEntry();
          renderToolCall(p, event.at);
          return;
        }
        if (kind === "plan") {
          finalizeAssistantEntry();
          renderPlan(p, event.at);
          return;
        }
        finalizeAssistantEntry();
        appendLog("update", kind || payload.method || "unknown", { at: event.at });
      }
      function resetSessionLog() {
        finalizeAssistantEntry();
        toolCallEntries.clear();
        thinkingEntries.clear();
      }
      async function openEventStream(id) {
        closeEventStream();
        const ctrl = new AbortController();
        sseCtrl = ctrl;
        const streamId = id;
        try {
          const res = await fetch(
            "/v1/sessions/" + encodeURIComponent(id) + "/events",
            { headers: { ...authHeader(), Accept: "text/event-stream" }, signal: ctrl.signal },
          );
          if (!res.ok || !res.body) {
            appendLog("error", "Stream open failed: HTTP " + res.status, null);
            return;
          }
          const reader = res.body.getReader();
          const decoder = new TextDecoder();
          let buf = "";
          while (selectedSession === streamId && sseCtrl === ctrl) {
            const { done, value } = await reader.read();
            if (done) break;
            buf += decoder.decode(value, { stream: true });
            let idx;
            while ((idx = buf.indexOf("\n\n")) >= 0) {
              const chunk = buf.slice(0, idx);
              buf = buf.slice(idx + 2);
              const dataLine = chunk.split("\n").find((l) => l.startsWith("data: "));
              if (!dataLine) continue;
              try {
                handleSseEvent(JSON.parse(dataLine.slice(6)));
              } catch (e) {
                appendLog("error", "Bad SSE frame: " + e.message, null);
              }
            }
          }
        } catch (e) {
          if (e.name !== "AbortError") appendLog("error", "Stream error: " + e.message, null);
        }
      }

      // ── Wiring ───────────────────────────────────────────────────────────
      document.getElementById("token-form").addEventListener("submit", (ev) => {
        ev.preventDefault();
        const t = $("token-input").value.trim();
        if (!t) return;
        setToken(t);
        showDashboard();
        loadMetrics("today");
        loadProjects();
        loadHeatmaps();
        loadRateLimits();
      });
      document.querySelectorAll(".tabs button[data-tab]").forEach((btn) => {
        btn.addEventListener("click", () => {
          document
            .querySelectorAll(".tabs button[data-tab]")
            .forEach((b) => b.classList.remove("active"));
          btn.classList.add("active");
          const tab = btn.dataset.tab;
          $("tab-metrics").hidden = tab !== "metrics";
          $("tab-sessions").hidden = tab !== "sessions";
          if (tab === "sessions") refreshSessions();
        });
      });
      document.querySelectorAll(".range-tabs button[data-range]").forEach((btn) => {
        btn.addEventListener("click", () => {
          document
            .querySelectorAll(".range-tabs button[data-range]")
            .forEach((b) => b.classList.remove("active"));
          btn.classList.add("active");
          loadMetrics(btn.dataset.range);
        });
      });
      $("logout").addEventListener("click", () => {
        closeEventStream();
        stopSessionsPoll();
        clearToken();
        showAuth();
      });
      $("new-session-form").addEventListener("submit", async (ev) => {
        ev.preventDefault();
        const cwd = $("new-session-cwd").value.trim();
        if (!cwd) return;
        try {
          const res = await apiFetch("/v1/sessions", {
            method: "POST",
            body: JSON.stringify({ cwd }),
          });
          if (!res.ok) {
            const body = await res.text();
            $("sessions-list").innerHTML =
              '<div class="error">Create failed: ' + escape(body) + "</div>";
            return;
          }
          const session = await res.json();
          $("new-session-cwd").value = "";
          refreshSessions();
          selectSession(session.id);
        } catch (e) {
          $("sessions-list").innerHTML =
            '<div class="error">Create failed: ' + escape(e.message) + "</div>";
        }
      });
      $("prompt-form").addEventListener("submit", (ev) => {
        ev.preventDefault();
        submitPromptFromTextarea();
      });
      function submitPromptFromTextarea() {
        const ta = $("prompt-text");
        const text = ta.value.trim();
        if (!text) return;
        ta.value = "";
        autoResizeTextarea(ta);
        sendPrompt(text);
      }
      function autoResizeTextarea(ta) {
        ta.style.height = "auto";
        ta.style.height = Math.min(240, Math.max(64, ta.scrollHeight)) + "px";
      }
      // v0.19.0: keyboard shortcuts on the prompt textarea.
      // Enter         -> send
      // Shift+Enter   -> newline (default browser behavior)
      // Ctrl+L / Cmd+L -> clear the response log
      // Esc           -> blur (unfocus)
      $("prompt-text").addEventListener("keydown", (ev) => {
        if (ev.key === "Enter" && !ev.shiftKey && !ev.isComposing) {
          ev.preventDefault();
          submitPromptFromTextarea();
          return;
        }
        if (ev.key === "l" && (ev.ctrlKey || ev.metaKey)) {
          ev.preventDefault();
          $("response-pane").innerHTML = "";
          resetSessionLog();
          appendLog("info", "(log cleared)", null);
          return;
        }
        if (ev.key === "Escape") {
          ev.preventDefault();
          ev.target.blur();
        }
      });
      $("prompt-text").addEventListener("input", (ev) => autoResizeTextarea(ev.target));
      $("delete-session").addEventListener("click", () => deleteSession());

      if (getToken()) {
        showDashboard();
        loadMetrics("today");
        loadProjects();
        loadHeatmaps();
        loadRateLimits();
      } else {
        showAuth();
      }
    </script>
  </body>
</html>
