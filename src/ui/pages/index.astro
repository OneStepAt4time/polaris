---
const title = "Polaris";
const tagline = "Self-hosted observatory for your AI coding agents";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — {tagline}</title>
    <style>
      * {
        box-sizing: border-box;
      }
      :root {
        --bg: #0a0a0a;
        --bg-card: #15151a;
        --fg: #e5e5e5;
        --fg-dim: #8a8a8a;
        --accent: #ffd54a;
        --border: #2a2a2a;
        --danger: #ff6666;
      }
      body {
        font-family: ui-monospace, "SF Mono", Consolas, "Liberation Mono", monospace;
        background: var(--bg);
        color: var(--fg);
        margin: 0;
        padding: 2rem 1.5rem;
        max-width: 1200px;
        margin-inline: auto;
        line-height: 1.5;
      }
      h1 {
        color: var(--accent);
        margin: 0;
        font-size: 1.5rem;
        letter-spacing: 0.04em;
      }
      .tagline {
        color: var(--fg-dim);
        margin: 0 0 2rem;
        font-size: 0.875rem;
      }
      .kpis {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 0.75rem;
        margin: 1.5rem 0;
      }
      .kpi {
        background: var(--bg-card);
        padding: 0.875rem 1rem;
        border-left: 3px solid var(--accent);
      }
      .kpi-label {
        font-size: 0.7rem;
        color: var(--fg-dim);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .kpi-value {
        font-size: 1.4rem;
        color: var(--fg);
        margin-top: 0.25rem;
      }
      .per-model {
        margin-top: 2rem;
      }
      .model-row {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 1rem;
        padding: 0.5rem 0;
        border-bottom: 1px solid var(--border);
        font-size: 0.875rem;
      }
      .model-row.header {
        color: var(--fg-dim);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      form.token-form {
        display: flex;
        gap: 0.5rem;
        margin: 1.5rem 0;
        max-width: 480px;
      }
      input,
      button {
        font-family: inherit;
        font-size: 0.875rem;
      }
      input {
        background: var(--bg-card);
        border: 1px solid var(--border);
        color: var(--fg);
        padding: 0.5rem 0.75rem;
        flex: 1;
      }
      button {
        background: var(--accent);
        color: #000;
        border: none;
        padding: 0.5rem 1rem;
        cursor: pointer;
        font-weight: 600;
      }
      .range-tabs {
        display: flex;
        gap: 0.5rem;
        margin: 1rem 0;
      }
      .range-tabs button {
        background: var(--bg-card);
        color: var(--fg);
        border: 1px solid var(--border);
        font-weight: normal;
      }
      .range-tabs button.active {
        background: var(--accent);
        color: #000;
        border-color: var(--accent);
        font-weight: 600;
      }
      .error {
        color: var(--danger);
      }
      .muted {
        color: var(--fg-dim);
      }
      a {
        color: var(--accent);
      }
      .logout {
        background: transparent;
        color: var(--fg-dim);
        border: 1px solid var(--border);
        font-size: 0.75rem;
        padding: 0.25rem 0.5rem;
        margin-left: 0.5rem;
      }
    </style>
  </head>
  <body>
    <h1>★ {title}</h1>
    <p class="tagline">{tagline}.</p>

    <section id="auth-pane">
      <p class="muted">
        Enter the bearer token configured via <code>POLARIS_AUTH_TOKEN</code>. Stored
        in your browser's localStorage; never sent anywhere except this Polaris
        instance.
      </p>
      <form id="token-form" class="token-form">
        <input
          type="password"
          id="token-input"
          autocomplete="off"
          placeholder="POLARIS_AUTH_TOKEN"
          required
        />
        <button type="submit">Unlock</button>
      </form>
    </section>

    <section id="dashboard" hidden>
      <div class="range-tabs" role="tablist">
        <button data-range="today" class="active">Today</button>
        <button data-range="7d">7 days</button>
        <button data-range="30d">30 days</button>
        <button data-range="all">All</button>
        <button id="logout" class="logout">Logout</button>
      </div>
      <div id="kpis" class="kpis"></div>
      <div id="per-model" class="per-model"></div>
      <p class="muted" id="range-meta"></p>
    </section>

    <script is:inline>
      const TOKEN_KEY = "polaris.token";
      const getToken = () => localStorage.getItem(TOKEN_KEY);
      const setToken = (t) => localStorage.setItem(TOKEN_KEY, t);
      const clearToken = () => localStorage.removeItem(TOKEN_KEY);

      const formatUsd = (n) => {
        if (!Number.isFinite(n) || n <= 0) return "$0";
        if (n >= 1000) return "$" + (n / 1000).toFixed(1) + "K";
        if (n >= 100) return "$" + n.toFixed(0);
        if (n >= 1) return "$" + n.toFixed(2);
        return "¢" + (n * 100).toFixed(0);
      };
      const formatTokens = (n) => {
        if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + "M";
        if (n >= 1_000) return (n / 1_000).toFixed(1) + "K";
        return String(n);
      };

      const $ = (id) => document.getElementById(id);
      const showAuth = () => {
        $("auth-pane").hidden = false;
        $("dashboard").hidden = true;
      };
      const showDashboard = () => {
        $("auth-pane").hidden = true;
        $("dashboard").hidden = false;
      };

      async function fetchMetrics(range) {
        const token = getToken();
        if (!token) throw new Error("No token");
        const res = await fetch("/v1/metrics?range=" + encodeURIComponent(range), {
          headers: { Authorization: "Bearer " + token },
        });
        if (res.status === 401) {
          clearToken();
          showAuth();
          throw new Error("Token rejected");
        }
        if (!res.ok) throw new Error("HTTP " + res.status);
        return res.json();
      }

      function render(data) {
        const kpis = [
          { label: "Total cost", value: formatUsd(data.totals.costUsd) },
          { label: "Events", value: String(data.totals.events) },
          { label: "Input tokens", value: formatTokens(data.totals.inputTokens) },
          { label: "Output tokens", value: formatTokens(data.totals.outputTokens) },
          { label: "Cache reads", value: formatTokens(data.totals.cacheReadTokens) },
        ];
        $("kpis").innerHTML = kpis
          .map(
            (k) =>
              '<div class="kpi"><div class="kpi-label">' +
              k.label +
              '</div><div class="kpi-value">' +
              k.value +
              "</div></div>",
          )
          .join("");

        const header =
          '<div class="model-row header"><div>Model</div><div>Events</div><div>Tokens</div><div>Cost</div></div>';
        const rows = data.perModel
          .map(
            (m) =>
              '<div class="model-row"><div>' +
              m.model +
              "</div><div>" +
              m.events +
              ' events</div><div>' +
              formatTokens(m.inputTokens + m.outputTokens) +
              " tok</div><div>" +
              formatUsd(m.costUsd) +
              "</div></div>",
          )
          .join("");
        $("per-model").innerHTML =
          rows.length > 0 ? header + rows : '<p class="muted">No events in this range yet.</p>';

        $("range-meta").textContent =
          "Range: " +
          data.range +
          " · " +
          new Date(data.fromMs).toISOString() +
          " → " +
          new Date(data.toMs).toISOString();
      }

      async function load(range) {
        try {
          const data = await fetchMetrics(range);
          render(data);
        } catch (e) {
          $("kpis").innerHTML = '<div class="error">Failed to load: ' + e.message + "</div>";
          $("per-model").innerHTML = "";
        }
      }

      document.getElementById("token-form").addEventListener("submit", (ev) => {
        ev.preventDefault();
        const t = $("token-input").value.trim();
        if (!t) return;
        setToken(t);
        showDashboard();
        load("today");
      });

      document.querySelectorAll(".range-tabs button[data-range]").forEach((btn) => {
        btn.addEventListener("click", () => {
          document
            .querySelectorAll(".range-tabs button[data-range]")
            .forEach((b) => b.classList.remove("active"));
          btn.classList.add("active");
          load(btn.dataset.range);
        });
      });

      $("logout").addEventListener("click", () => {
        clearToken();
        showAuth();
      });

      if (getToken()) {
        showDashboard();
        load("today");
      } else {
        showAuth();
      }
    </script>
  </body>
</html>
