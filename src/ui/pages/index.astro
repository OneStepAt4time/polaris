---
const title = "Polaris";
const tagline = "Self-hosted observatory for your AI coding agents";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — {tagline}</title>
    <style>
      * {
        box-sizing: border-box;
      }
      :root {
        --bg: #0a0a0a;
        --bg-card: #15151a;
        --fg: #e5e5e5;
        --fg-dim: #8a8a8a;
        --accent: #ffd54a;
        --border: #2a2a2a;
        --danger: #ff6666;
        --success: #66cc66;
      }
      body {
        font-family: ui-monospace, "SF Mono", Consolas, "Liberation Mono", monospace;
        background: var(--bg);
        color: var(--fg);
        margin: 0;
        padding: 2rem 1.5rem;
        max-width: 1200px;
        margin-inline: auto;
        line-height: 1.5;
      }
      h1 {
        color: var(--accent);
        margin: 0;
        font-size: 1.5rem;
        letter-spacing: 0.04em;
      }
      h2 {
        font-size: 1rem;
        color: var(--fg);
        margin: 1.5rem 0 0.5rem;
      }
      .tagline {
        color: var(--fg-dim);
        margin: 0 0 2rem;
        font-size: 0.875rem;
      }
      .kpis {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 0.75rem;
        margin: 1.5rem 0;
      }
      .kpi {
        background: var(--bg-card);
        padding: 0.875rem 1rem;
        border-left: 3px solid var(--accent);
      }
      .kpi-label {
        font-size: 0.7rem;
        color: var(--fg-dim);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .kpi-value {
        font-size: 1.4rem;
        color: var(--fg);
        margin-top: 0.25rem;
      }
      .per-model {
        margin-top: 2rem;
      }
      .model-row {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 1rem;
        padding: 0.5rem 0;
        border-bottom: 1px solid var(--border);
        font-size: 0.875rem;
      }
      .model-row.header {
        color: var(--fg-dim);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      form.token-form {
        display: flex;
        gap: 0.5rem;
        margin: 1.5rem 0;
        max-width: 480px;
      }
      input,
      button,
      textarea {
        font-family: inherit;
        font-size: 0.875rem;
      }
      input,
      textarea {
        background: var(--bg-card);
        border: 1px solid var(--border);
        color: var(--fg);
        padding: 0.5rem 0.75rem;
        flex: 1;
      }
      textarea {
        resize: vertical;
        min-height: 64px;
        width: 100%;
        display: block;
      }
      button {
        background: var(--accent);
        color: #000;
        border: none;
        padding: 0.5rem 1rem;
        cursor: pointer;
        font-weight: 600;
      }
      button.secondary {
        background: var(--bg-card);
        color: var(--fg);
        border: 1px solid var(--border);
        font-weight: 400;
      }
      button.danger {
        background: transparent;
        color: var(--danger);
        border: 1px solid var(--danger);
        font-weight: 400;
      }
      button.success {
        background: var(--success);
        color: #000;
      }
      .tabs,
      .range-tabs {
        display: flex;
        gap: 0.5rem;
        margin: 1rem 0;
      }
      .tabs button,
      .range-tabs button {
        background: var(--bg-card);
        color: var(--fg);
        border: 1px solid var(--border);
        font-weight: normal;
      }
      .tabs button.active,
      .range-tabs button.active {
        background: var(--accent);
        color: #000;
        border-color: var(--accent);
        font-weight: 600;
      }
      .error {
        color: var(--danger);
      }
      .muted {
        color: var(--fg-dim);
      }
      a {
        color: var(--accent);
      }
      .logout {
        background: transparent;
        color: var(--fg-dim);
        border: 1px solid var(--border);
        font-size: 0.75rem;
        padding: 0.25rem 0.5rem;
        margin-left: auto;
      }
      .session-card {
        background: var(--bg-card);
        padding: 1rem;
        margin: 0.75rem 0;
        border-left: 3px solid var(--accent);
        cursor: pointer;
      }
      .session-card.selected {
        border-left-color: var(--success);
      }
      .session-header {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        font-size: 0.8125rem;
      }
      .session-id {
        font-family: inherit;
        color: var(--fg-dim);
      }
      .session-cwd {
        color: var(--fg);
      }
      .new-session {
        display: flex;
        gap: 0.5rem;
        margin: 1rem 0;
      }
      .new-session input {
        flex: 1;
      }
      .prompt-form {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin: 1rem 0;
      }
      .prompt-form .row {
        display: flex;
        gap: 0.5rem;
      }
      .response-pane {
        background: var(--bg-card);
        border: 1px solid var(--border);
        padding: 0.75rem 1rem;
        margin-top: 1rem;
        font-size: 0.8125rem;
        white-space: pre-wrap;
        max-height: 360px;
        overflow-y: auto;
      }
    </style>
  </head>
  <body>
    <h1>★ {title}</h1>
    <p class="tagline">{tagline}.</p>

    <section id="auth-pane">
      <p class="muted">
        Enter the bearer token configured via <code>POLARIS_AUTH_TOKEN</code>. Stored
        in your browser's localStorage; never sent anywhere except this Polaris
        instance.
      </p>
      <form id="token-form" class="token-form">
        <input
          type="password"
          id="token-input"
          autocomplete="off"
          placeholder="POLARIS_AUTH_TOKEN"
          required
        />
        <button type="submit">Unlock</button>
      </form>
    </section>

    <section id="dashboard" hidden>
      <div class="tabs" role="tablist">
        <button data-tab="metrics" class="active">Metrics</button>
        <button data-tab="sessions">Sessions</button>
        <button id="logout" class="logout">Logout</button>
      </div>

      <div id="tab-metrics">
        <div class="range-tabs" role="tablist">
          <button data-range="today" class="active">Today</button>
          <button data-range="7d">7 days</button>
          <button data-range="30d">30 days</button>
          <button data-range="all">All</button>
        </div>
        <div id="kpis" class="kpis"></div>
        <div id="per-model" class="per-model"></div>
        <p class="muted" id="range-meta"></p>
      </div>

      <div id="tab-sessions" hidden>
        <h2>New session</h2>
        <form id="new-session-form" class="new-session">
          <input
            type="text"
            id="new-session-cwd"
            placeholder="Working directory (absolute path)"
            required
          />
          <button type="submit">Create</button>
        </form>
        <h2>Active sessions</h2>
        <div id="sessions-list"></div>
        <div id="session-detail" hidden>
          <h2>Selected session</h2>
          <form id="prompt-form" class="prompt-form">
            <textarea id="prompt-text" placeholder="Type a prompt..." required></textarea>
            <div class="row">
              <button type="submit">Send prompt</button>
              <button type="button" id="delete-session" class="danger">Delete session</button>
            </div>
          </form>
          <div id="response-pane" class="response-pane muted">No prompt sent yet.</div>
        </div>
      </div>
    </section>

    <script is:inline>
      const TOKEN_KEY = "polaris.token";
      const getToken = () => localStorage.getItem(TOKEN_KEY);
      const setToken = (t) => localStorage.setItem(TOKEN_KEY, t);
      const clearToken = () => localStorage.removeItem(TOKEN_KEY);

      const formatUsd = (n) => {
        if (!Number.isFinite(n) || n <= 0) return "$0";
        if (n >= 1000) return "$" + (n / 1000).toFixed(1) + "K";
        if (n >= 100) return "$" + n.toFixed(0);
        if (n >= 1) return "$" + n.toFixed(2);
        return "¢" + (n * 100).toFixed(0);
      };
      const formatTokens = (n) => {
        if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + "M";
        if (n >= 1_000) return (n / 1_000).toFixed(1) + "K";
        return String(n);
      };
      const escape = (s) =>
        String(s).replace(/[&<>"']/g, (c) => ({
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;",
        })[c]);

      const $ = (id) => document.getElementById(id);
      const authHeader = () => ({ Authorization: "Bearer " + getToken() });

      const showAuth = () => {
        $("auth-pane").hidden = false;
        $("dashboard").hidden = true;
      };
      const showDashboard = () => {
        $("auth-pane").hidden = true;
        $("dashboard").hidden = false;
      };

      async function apiFetch(path, init = {}) {
        const res = await fetch(path, {
          ...init,
          headers: {
            "content-type": "application/json",
            ...authHeader(),
            ...(init.headers || {}),
          },
        });
        if (res.status === 401) {
          clearToken();
          showAuth();
          throw new Error("Token rejected");
        }
        return res;
      }

      // ── Metrics tab ──────────────────────────────────────────────────────
      async function fetchMetrics(range) {
        const res = await apiFetch("/v1/metrics?range=" + encodeURIComponent(range));
        if (!res.ok) throw new Error("HTTP " + res.status);
        return res.json();
      }
      function renderMetrics(data) {
        const kpis = [
          { label: "Total cost", value: formatUsd(data.totals.costUsd) },
          { label: "Events", value: String(data.totals.events) },
          { label: "Input tokens", value: formatTokens(data.totals.inputTokens) },
          { label: "Output tokens", value: formatTokens(data.totals.outputTokens) },
          { label: "Cache reads", value: formatTokens(data.totals.cacheReadTokens) },
        ];
        $("kpis").innerHTML = kpis
          .map(
            (k) =>
              '<div class="kpi"><div class="kpi-label">' +
              k.label +
              '</div><div class="kpi-value">' +
              k.value +
              "</div></div>",
          )
          .join("");
        const header =
          '<div class="model-row header"><div>Model</div><div>Events</div><div>Tokens</div><div>Cost</div></div>';
        const rows = data.perModel
          .map(
            (m) =>
              '<div class="model-row"><div>' +
              escape(m.model) +
              "</div><div>" +
              m.events +
              " events</div><div>" +
              formatTokens(m.inputTokens + m.outputTokens) +
              " tok</div><div>" +
              formatUsd(m.costUsd) +
              "</div></div>",
          )
          .join("");
        $("per-model").innerHTML =
          rows.length > 0 ? header + rows : '<p class="muted">No events in this range yet.</p>';
        $("range-meta").textContent =
          "Range: " +
          data.range +
          " · " +
          new Date(data.fromMs).toISOString() +
          " → " +
          new Date(data.toMs).toISOString();
      }
      async function loadMetrics(range) {
        try {
          renderMetrics(await fetchMetrics(range));
        } catch (e) {
          $("kpis").innerHTML = '<div class="error">Failed to load: ' + escape(e.message) + "</div>";
          $("per-model").innerHTML = "";
        }
      }

      // ── Sessions tab ─────────────────────────────────────────────────────
      // v0.6.0 ships the basic registry: list / create / prompt (sync) / delete.
      // Live SSE event stream + inline approval buttons land in v0.6.1; until
      // then the SessionManager auto-resolves nothing — a prompt that needs a
      // permission hangs until the per-approval 5-min timeout cancels it.
      let selectedSession = null;

      async function refreshSessions() {
        try {
          const res = await apiFetch("/v1/sessions");
          if (!res.ok) throw new Error("HTTP " + res.status);
          const { sessions } = await res.json();
          renderSessions(sessions);
        } catch (e) {
          $("sessions-list").innerHTML =
            '<div class="error">Failed to load: ' + escape(e.message) + "</div>";
        }
      }
      function renderSessions(sessions) {
        if (!sessions.length) {
          $("sessions-list").innerHTML = '<p class="muted">No active sessions.</p>';
          return;
        }
        $("sessions-list").innerHTML = sessions
          .map(
            (s) =>
              '<div class="session-card' +
              (s.id === selectedSession ? " selected" : "") +
              '" data-session-id="' +
              escape(s.id) +
              '"><div class="session-header"><span class="session-cwd">' +
              escape(s.cwd) +
              '</span><span class="session-id">' +
              escape(s.id.slice(0, 12)) +
              " · " +
              escape(s.status) +
              "</span></div></div>",
          )
          .join("");
        document.querySelectorAll(".session-card").forEach((el) => {
          el.addEventListener("click", () => selectSession(el.dataset.sessionId));
        });
      }
      function selectSession(id) {
        selectedSession = id;
        $("session-detail").hidden = false;
        $("response-pane").className = "response-pane muted";
        $("response-pane").textContent = "No prompt sent yet.";
        refreshSessions();
      }
      async function sendPrompt(text) {
        if (!selectedSession) return;
        $("response-pane").className = "response-pane muted";
        $("response-pane").textContent = "→ " + text + "\n\nWaiting for response…";
        try {
          const res = await apiFetch(
            "/v1/sessions/" + encodeURIComponent(selectedSession) + "/messages",
            { method: "POST", body: JSON.stringify({ text }) },
          );
          if (!res.ok) {
            $("response-pane").className = "response-pane error";
            $("response-pane").textContent = "HTTP " + res.status + ": " + (await res.text());
            return;
          }
          const result = await res.json();
          $("response-pane").className = "response-pane";
          $("response-pane").textContent =
            "→ " + text + "\n\nstopReason=" + result.stopReason +
            "\nupdates=" + (result.updates?.length ?? 0);
        } catch (e) {
          $("response-pane").className = "response-pane error";
          $("response-pane").textContent = "Error: " + e.message;
        }
      }
      async function deleteSession() {
        if (!selectedSession) return;
        await apiFetch("/v1/sessions/" + encodeURIComponent(selectedSession), {
          method: "DELETE",
        });
        selectedSession = null;
        $("session-detail").hidden = true;
        refreshSessions();
      }

      // ── Wiring ───────────────────────────────────────────────────────────
      document.getElementById("token-form").addEventListener("submit", (ev) => {
        ev.preventDefault();
        const t = $("token-input").value.trim();
        if (!t) return;
        setToken(t);
        showDashboard();
        loadMetrics("today");
      });
      document.querySelectorAll(".tabs button[data-tab]").forEach((btn) => {
        btn.addEventListener("click", () => {
          document
            .querySelectorAll(".tabs button[data-tab]")
            .forEach((b) => b.classList.remove("active"));
          btn.classList.add("active");
          const tab = btn.dataset.tab;
          $("tab-metrics").hidden = tab !== "metrics";
          $("tab-sessions").hidden = tab !== "sessions";
          if (tab === "sessions") refreshSessions();
        });
      });
      document.querySelectorAll(".range-tabs button[data-range]").forEach((btn) => {
        btn.addEventListener("click", () => {
          document
            .querySelectorAll(".range-tabs button[data-range]")
            .forEach((b) => b.classList.remove("active"));
          btn.classList.add("active");
          loadMetrics(btn.dataset.range);
        });
      });
      $("logout").addEventListener("click", () => {
        clearToken();
        showAuth();
      });
      $("new-session-form").addEventListener("submit", async (ev) => {
        ev.preventDefault();
        const cwd = $("new-session-cwd").value.trim();
        if (!cwd) return;
        try {
          const res = await apiFetch("/v1/sessions", {
            method: "POST",
            body: JSON.stringify({ cwd }),
          });
          if (!res.ok) {
            const body = await res.text();
            $("sessions-list").innerHTML =
              '<div class="error">Create failed: ' + escape(body) + "</div>";
            return;
          }
          const session = await res.json();
          $("new-session-cwd").value = "";
          refreshSessions();
          selectSession(session.id);
        } catch (e) {
          $("sessions-list").innerHTML =
            '<div class="error">Create failed: ' + escape(e.message) + "</div>";
        }
      });
      $("prompt-form").addEventListener("submit", (ev) => {
        ev.preventDefault();
        const text = $("prompt-text").value.trim();
        if (!text) return;
        $("prompt-text").value = "";
        sendPrompt(text);
      });
      $("delete-session").addEventListener("click", () => deleteSession());

      if (getToken()) {
        showDashboard();
        loadMetrics("today");
      } else {
        showAuth();
      }
    </script>
  </body>
</html>
