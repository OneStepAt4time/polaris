        // the only data we have; for active sessions, it brings the new view
        // up to date with what happened before the user selected.
        try {
          const res = await apiFetch("/v1/sessions/" + encodeURIComponent(id) + "/transcript");
          if (res.ok) {
            const body = await res.json();
            const messages = Array.isArray(body.messages) ? body.messages : [];
            for (const m of messages) {
