          const res = await apiFetch(
            "/v1/sessions/" + encodeURIComponent(selectedSession) + "/messages",
            { method: "POST", body: JSON.stringify({ text }) },
          );
          if (!res.ok) {
            appendLog("error", "HTTP " + res.status + ": " + (await res.text()), null);
            return;
          }
          const result = await res.json();
          finalizeAssistantEntry();
          appendLog(
            "done",
            "stopReason=" + result.stopReason + " · updates=" + (result.updates?.length ?? 0),
            null,
          );
        } catch (e) {
          appendLog("error", "Error: " + e.message, null);
        }
      }
      async function deleteSession() {
        if (!selectedSession) return;
