---
const title = "Polaris";
const tagline = "Self-hosted observatory for your AI coding agents";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — {tagline}</title>
    <style is:global>
      * {
        box-sizing: border-box;
      }
      :root {
        --bg: #0a0a0a;
        --bg-card: #15151a;
        --fg: #e5e5e5;
        --fg-dim: #8a8a8a;
        --accent: #ffd54a;
        --border: #2a2a2a;
        --danger: #ff6666;
        --success: #66cc66;
      }
      body {
        font-family: ui-monospace, "SF Mono", Consolas, "Liberation Mono", monospace;
        background: var(--bg);
        color: var(--fg);
        margin: 0;
        padding: 2rem 1.5rem;
        max-width: 1200px;
        margin-inline: auto;
        line-height: 1.5;
      }
      h1 {
        color: var(--accent);
        margin: 0;
        font-size: 1.5rem;
        letter-spacing: 0.04em;
      }
      h2 {
        font-size: 1rem;
        color: var(--fg);
        margin: 1.5rem 0 0.5rem;
      }
      .tagline {
        color: var(--fg-dim);
        margin: 0 0 2rem;
        font-size: 0.875rem;
      }
      .kpis {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 0.75rem;
        margin: 1.5rem 0;
      }
      .kpi {
        background: var(--bg-card);
        padding: 0.875rem 1rem;
        border-left: 3px solid var(--accent);
      }
      .kpi-label {
        font-size: 0.7rem;
        color: var(--fg-dim);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .kpi-value {
        font-size: 1.4rem;
        color: var(--fg);
        margin-top: 0.25rem;
      }
      .per-model {
        margin-top: 2rem;
      }
      .model-row {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 1rem;
        padding: 0.5rem 0;
        border-bottom: 1px solid var(--border);
        font-size: 0.875rem;
      }
      .model-row.header {
        color: var(--fg-dim);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      form.token-form {
        display: flex;
        gap: 0.5rem;
        margin: 1.5rem 0;
        max-width: 480px;
      }
      input,
      button,
      textarea {
        font-family: inherit;
        font-size: 0.875rem;
      }
      input,
      textarea {
        background: var(--bg-card);
        border: 1px solid var(--border);
        color: var(--fg);
        padding: 0.5rem 0.75rem;
        flex: 1;
      }
      textarea {
        resize: vertical;
        min-height: 64px;
        width: 100%;
        display: block;
      }
      button {
        background: var(--accent);
        color: #000;
        border: none;
        padding: 0.5rem 1rem;
        cursor: pointer;
        font-weight: 600;
      }
      button.secondary {
        background: var(--bg-card);
        color: var(--fg);
        border: 1px solid var(--border);
        font-weight: 400;
      }
      button.danger {
        background: transparent;
        color: var(--danger);
        border: 1px solid var(--danger);
        font-weight: 400;
      }
      button.success {
        background: var(--success);
        color: #000;
      }
      .tabs,
      .range-tabs {
        display: flex;
        gap: 0.5rem;
        margin: 1rem 0;
      }
      .tabs button,
      .range-tabs button {
        background: var(--bg-card);
        color: var(--fg);
        border: 1px solid var(--border);
        font-weight: normal;
      }
      .tabs button.active,
      .range-tabs button.active {
        background: var(--accent);
        color: #000;
        border-color: var(--accent);
        font-weight: 600;
      }
      .error {
        color: var(--danger);
      }
      .muted {
        color: var(--fg-dim);
      }
      a {
        color: var(--accent);
      }
      .logout {
        background: transparent;
        color: var(--fg-dim);
        border: 1px solid var(--border);
        font-size: 0.75rem;
        padding: 0.25rem 0.5rem;
        margin-left: auto;
      }
      .session-card {
        background: var(--bg-card);
        padding: 1rem;
        margin: 0.75rem 0;
        border-left: 3px solid var(--accent);
        cursor: pointer;
      }
      .session-card.selected {
        border-left-color: var(--success);
      }
      .session-header {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        font-size: 0.8125rem;
      }
      .session-id {
        font-family: inherit;
        color: var(--fg-dim);
      }
      .session-cwd {
        color: var(--fg);
      }
      .new-session {
        display: flex;
        gap: 0.5rem;
        margin: 1rem 0;
      }
      .new-session input {
        flex: 1;
      }
      .prompt-form {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin: 1rem 0;
      }
      .prompt-form .row {
        display: flex;
        gap: 0.5rem;
      }
      .response-pane {
        background: var(--bg-card);
        border: 1px solid var(--border);
        padding: 0.75rem 1rem;
        margin-top: 1rem;
        font-size: 0.8125rem;
        white-space: pre-wrap;
        max-height: 360px;
        overflow-y: auto;
      }
      .log-entry {
        display: flex;
        gap: 0.5rem;
        padding: 0.2rem 0;
        border-bottom: 1px solid var(--border);
        font-size: 0.75rem;
      }
      .log-entry:last-child {
        border-bottom: none;
      }
      .log-time {
        color: var(--fg-dim);
        flex: 0 0 auto;
        font-variant-numeric: tabular-nums;
      }
      .log-kind {
        color: var(--fg-dim);
        flex: 0 0 auto;
      }
      .log-body {
        flex: 1;
        word-break: break-word;
      }
      .log-entry.approval {
        background: rgba(255, 213, 74, 0.08);
        border-left: 3px solid var(--accent);
        padding-left: 0.5rem;
      }
      .log-entry.closed .log-kind {
        color: var(--success);
      }
      .log-actions {
        display: flex;
        gap: 0.4rem;
        margin-top: 0.4rem;
      }
      .log-actions button {
        font-size: 0.75rem;
        padding: 0.3rem 0.6rem;
      }
      .projects {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 0.75rem;
        margin-top: 0.5rem;
      }
      .project-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 0.75rem 1rem;
      }
      .project-name {
        font-size: 0.8125rem;
        color: var(--accent);
        word-break: break-all;
        margin-bottom: 0.5rem;
      }
      .project-stats {
        display: flex;
        justify-content: space-between;
        gap: 0.5rem;
        font-size: 0.75rem;
        margin-bottom: 0.5rem;
      }
      .project-cost {
        color: var(--fg);
        font-weight: 600;
      }
      .project-meta {
        color: var(--fg-dim);
      }
      .sparkline {
        display: block;
        width: 100%;
        height: 32px;
      }
      .sparkline path {
        fill: none;
        stroke: var(--accent);
        stroke-width: 1.5;
      }
      .sparkline .area {
        fill: var(--accent);
        opacity: 0.12;
        stroke: none;
      }
      .rate-limits {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 0.75rem 1rem;
        margin-top: 0.5rem;
        font-size: 0.8125rem;
      }
      .rate-meta {
        color: var(--fg-dim);
        font-size: 0.75rem;
        margin-bottom: 0.5rem;
      }
      .rate-bar {
        display: grid;
        grid-template-columns: 8rem 1fr 3rem;
        gap: 0.5rem;
        align-items: center;
        margin: 0.4rem 0;
      }
      .rate-bar-label {
        color: var(--fg);
      }
      .rate-bar-track {
        background: rgba(255, 255, 255, 0.06);
        height: 6px;
        border-radius: 3px;
        overflow: hidden;
      }
      .rate-bar-fill {
        height: 100%;
        background: var(--accent);
      }
      .rate-bar-fill.warn {
        background: #ffaa00;
      }
      .rate-bar-fill.danger {
        background: var(--danger);
      }
      .rate-bar-value {
        text-align: right;
        font-variant-numeric: tabular-nums;
        color: var(--fg-dim);
      }
      .rate-raw {
        margin-top: 0.5rem;
        font-size: 0.7rem;
        color: var(--fg-dim);
        max-height: 160px;
        overflow-y: auto;
        white-space: pre-wrap;
        word-break: break-all;
      }
    </style>
  </head>
  <body>
    <h1>★ {title}</h1>
    <p class="tagline">{tagline}.</p>

    <section id="auth-pane">
      <p class="muted">
        Enter the bearer token configured via <code>POLARIS_AUTH_TOKEN</code>. Stored
        in your browser's localStorage; never sent anywhere except this Polaris
        instance.
      </p>
      <form id="token-form" class="token-form">
        <input
          type="password"
          id="token-input"
          autocomplete="off"
          placeholder="POLARIS_AUTH_TOKEN"
          required
        />
        <button type="submit">Unlock</button>
      </form>
    </section>

    <section id="dashboard" hidden>
      <div class="tabs" role="tablist">
        <button data-tab="metrics" class="active">Metrics</button>
        <button data-tab="sessions">Sessions</button>
        <button id="logout" class="logout">Logout</button>
      </div>

      <div id="tab-metrics">
        <div class="range-tabs" role="tablist">
          <button data-range="today" class="active">Today</button>
          <button data-range="7d">7 days</button>
          <button data-range="30d">30 days</button>
          <button data-range="all">All</button>
        </div>
        <div id="kpis" class="kpis"></div>
        <div id="per-model" class="per-model"></div>
        <p class="muted" id="range-meta"></p>
        <h2>Projects (last 30 days)</h2>
        <div id="projects" class="projects"></div>

        <h2>Rate limits</h2>
        <div id="rate-limits" class="rate-limits"></div>
      </div>

      <div id="tab-sessions" hidden>
        <h2>New session</h2>
        <form id="new-session-form" class="new-session">
          <input
            type="text"
            id="new-session-cwd"
            placeholder="Working directory (absolute path)"
            required
          />
          <button type="submit">Create</button>
        </form>
        <h2>Active sessions</h2>
        <div id="sessions-list"></div>
        <div id="session-detail" hidden>
          <h2>Selected session</h2>
          <form id="prompt-form" class="prompt-form">
            <textarea id="prompt-text" placeholder="Type a prompt..." required></textarea>
            <div class="row">
              <button type="submit">Send prompt</button>
              <button type="button" id="delete-session" class="danger">Delete session</button>
            </div>
          </form>
          <div id="response-pane" class="response-pane muted">No prompt sent yet.</div>
        </div>
      </div>
    </section>

    <script is:inline>
      const TOKEN_KEY = "polaris.token";
      const getToken = () => localStorage.getItem(TOKEN_KEY);
      const setToken = (t) => localStorage.setItem(TOKEN_KEY, t);
      const clearToken = () => localStorage.removeItem(TOKEN_KEY);

      const formatUsd = (n) => {
        if (!Number.isFinite(n) || n <= 0) return "$0";
        if (n >= 1000) return "$" + (n / 1000).toFixed(1) + "K";
        if (n >= 100) return "$" + n.toFixed(0);
        if (n >= 1) return "$" + n.toFixed(2);
        return "¢" + (n * 100).toFixed(0);
      };
      const formatTokens = (n) => {
        if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + "M";
        if (n >= 1_000) return (n / 1_000).toFixed(1) + "K";
        return String(n);
      };
      const escape = (s) =>
        String(s).replace(/[&<>"']/g, (c) => ({
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;",
        })[c]);

      const $ = (id) => document.getElementById(id);
      const authHeader = () => ({ Authorization: "Bearer " + getToken() });

      const showAuth = () => {
        $("auth-pane").hidden = false;
        $("dashboard").hidden = true;
      };
      const showDashboard = () => {
        $("auth-pane").hidden = true;
        $("dashboard").hidden = false;
      };

      async function apiFetch(path, init = {}) {
        const res = await fetch(path, {
          ...init,
          headers: {
            "content-type": "application/json",
            ...authHeader(),
            ...(init.headers || {}),
          },
        });
        if (res.status === 401) {
          clearToken();
          showAuth();
          throw new Error("Token rejected");
        }
        return res;
      }

      // ── Metrics tab ──────────────────────────────────────────────────────
      async function fetchMetrics(range) {
        const res = await apiFetch("/v1/metrics?range=" + encodeURIComponent(range));
        if (!res.ok) throw new Error("HTTP " + res.status);
        return res.json();
      }
      function renderMetrics(data) {
        const kpis = [
          { label: "Total cost", value: formatUsd(data.totals.costUsd) },
          { label: "Events", value: String(data.totals.events) },
          { label: "Input tokens", value: formatTokens(data.totals.inputTokens) },
          { label: "Output tokens", value: formatTokens(data.totals.outputTokens) },
          { label: "Cache reads", value: formatTokens(data.totals.cacheReadTokens) },
        ];
        $("kpis").innerHTML = kpis
          .map(
            (k) =>
              '<div class="kpi"><div class="kpi-label">' +
              k.label +
              '</div><div class="kpi-value">' +
              k.value +
              "</div></div>",
          )
          .join("");
        const header =
          '<div class="model-row header"><div>Model</div><div>Events</div><div>Tokens</div><div>Cost</div></div>';
        const rows = data.perModel
          .map(
            (m) =>
              '<div class="model-row"><div>' +
              escape(m.model) +
              "</div><div>" +
              m.events +
              " events</div><div>" +
              formatTokens(m.inputTokens + m.outputTokens) +
              " tok</div><div>" +
              formatUsd(m.costUsd) +
              "</div></div>",
          )
          .join("");
        $("per-model").innerHTML =
          rows.length > 0 ? header + rows : '<p class="muted">No events in this range yet.</p>';
        $("range-meta").textContent =
          "Range: " +
          data.range +
          " · " +
          new Date(data.fromMs).toISOString() +
          " → " +
          new Date(data.toMs).toISOString();
      }
      async function loadMetrics(range) {
        try {
          renderMetrics(await fetchMetrics(range));
        } catch (e) {
          $("kpis").innerHTML = '<div class="error">Failed to load: ' + escape(e.message) + "</div>";
          $("per-model").innerHTML = "";
        }
      }

      // ── Projects (sparkline cards) ───────────────────────────────────────
      function sparklineSvg(values) {
        if (!Array.isArray(values) || values.length === 0) return "";
        const w = 260;
        const h = 32;
        const max = Math.max(0.0001, ...values);
        const step = values.length > 1 ? w / (values.length - 1) : 0;
        const pts = values.map((v, i) => {
          const x = i * step;
          const y = h - (v / max) * (h - 2) - 1;
          return x.toFixed(1) + "," + y.toFixed(1);
        });
        const linePath = "M" + pts.join(" L");
        const areaPath = linePath + " L" + w.toFixed(1) + "," + h + " L0," + h + " Z";
        return (
          '<svg class="sparkline" viewBox="0 0 ' + w + " " + h +
          '" preserveAspectRatio="none">' +
          '<path class="area" d="' + areaPath + '"/>' +
          '<path d="' + linePath + '"/>' +
          "</svg>"
        );
      }
      async function fetchProjects(days = 30) {
        const res = await apiFetch("/v1/projects?days=" + days);
        if (!res.ok) throw new Error("HTTP " + res.status);
        return res.json();
      }
      function renderProjects(data) {
        if (!data.projects || data.projects.length === 0) {
          $("projects").innerHTML = '<p class="muted">No project data in the last 30 days.</p>';
          return;
        }
        $("projects").innerHTML = data.projects
          .map(
            (p) =>
              '<div class="project-card"><div class="project-name">' +
              escape(p.name) +
              '</div><div class="project-stats"><span class="project-cost">' +
              formatUsd(p.costUsd) +
              '</span><span class="project-meta">' +
              p.sessions +
              " sess · " +
              p.events +
              " ev · " +
              formatTokens(p.outputTokens) +
              " out</span></div>" +
              sparklineSvg(p.dailyCostUsd) +
              "</div>",
          )
          .join("");
      }
      async function loadProjects() {
        try {
          renderProjects(await fetchProjects(30));
        } catch (e) {
          $("projects").innerHTML =
            '<div class="error">Failed to load projects: ' + escape(e.message) + "</div>";
        }
      }

      // ── Rate limits ──────────────────────────────────────────────────────
      function rateBar(label, utilization) {
        const u = Math.max(0, Math.min(1, Number(utilization) || 0));
        const pct = (u * 100).toFixed(0);
        const cls = u >= 0.9 ? "danger" : u >= 0.75 ? "warn" : "";
        return (
          '<div class="rate-bar"><div class="rate-bar-label">' +
          escape(label) +
          '</div><div class="rate-bar-track"><div class="rate-bar-fill ' +
          cls +
          '" style="width:' +
          pct +
          '%"></div></div><div class="rate-bar-value">' +
          pct +
          "%</div></div>"
        );
      }
      function renderRateLimits(data) {
        const pane = $("rate-limits");
        if (data.error) {
          pane.innerHTML =
            '<div class="rate-meta">Last poll: ' +
            new Date(data.tsMs).toISOString() +
            " · HTTP " +
            data.httpStatus +
            '</div><div class="error">' +
            escape(data.error) +
            "</div>";
          return;
        }
        const payload = data.payload || {};
        const candidates = [
          ["5-hour window", payload.five_hour],
          ["7-day window", payload.seven_day],
          ["7-day Opus window", payload.seven_day_opus],
        ];
        const bars = [];
        for (const [label, window] of candidates) {
          if (window && typeof window === "object" && "utilization" in window) {
            bars.push(rateBar(label, window.utilization));
          }
        }
        const meta =
          '<div class="rate-meta">Last poll: ' +
          new Date(data.tsMs).toISOString() +
          " · HTTP " +
          data.httpStatus +
          "</div>";
        if (bars.length > 0) {
          pane.innerHTML = meta + bars.join("");
          return;
        }
        // Unknown response shape — show raw JSON so we can iterate without code changes.
        pane.innerHTML =
          meta +
          '<div class="rate-raw">' +
          escape(JSON.stringify(payload, null, 2)) +
          "</div>";
      }
      async function loadRateLimits() {
        try {
          const res = await apiFetch("/v1/rate-limits");
          if (res.status === 503) {
            const body = await res.json();
            $("rate-limits").innerHTML =
              '<p class="muted">' +
              (body.configured
                ? "Waiting for first poll (every ~8 min)."
                : "OAuth credentials not found at ~/.claude/.credentials.json — rate-limit tracking is disabled.") +
              "</p>";
            return;
          }
          if (!res.ok) throw new Error("HTTP " + res.status);
          renderRateLimits(await res.json());
        } catch (e) {
          $("rate-limits").innerHTML =
            '<div class="error">Failed to load rate limits: ' + escape(e.message) + "</div>";
        }
      }

      // ── Sessions tab ─────────────────────────────────────────────────────
      // v0.6.0 ships the basic registry: list / create / prompt (sync) / delete.
      // Live SSE event stream + inline approval buttons land in v0.6.1; until
      // then the SessionManager auto-resolves nothing — a prompt that needs a
      // permission hangs until the per-approval 5-min timeout cancels it.
      let selectedSession = null;

      async function refreshSessions() {
        try {
          const res = await apiFetch("/v1/sessions");
          if (!res.ok) throw new Error("HTTP " + res.status);
          const { sessions } = await res.json();
          renderSessions(sessions);
        } catch (e) {
          $("sessions-list").innerHTML =
            '<div class="error">Failed to load: ' + escape(e.message) + "</div>";
        }
      }
      function renderSessions(sessions) {
        if (!sessions.length) {
          $("sessions-list").innerHTML = '<p class="muted">No active sessions.</p>';
          return;
        }
        $("sessions-list").innerHTML = sessions
          .map(
            (s) =>
              '<div class="session-card' +
              (s.id === selectedSession ? " selected" : "") +
              '" data-session-id="' +
              escape(s.id) +
              '"><div class="session-header"><span class="session-cwd">' +
              escape(s.cwd) +
              '</span><span class="session-id">' +
              escape(s.id.slice(0, 12)) +
              " · " +
              escape(s.status) +
              "</span></div></div>",
          )
          .join("");
        document.querySelectorAll(".session-card").forEach((el) => {
          el.addEventListener("click", () => selectSession(el.dataset.sessionId));
        });
      }
      function selectSession(id) {
        selectedSession = id;
        $("session-detail").hidden = false;
        $("response-pane").className = "response-pane";
        $("response-pane").innerHTML = "";
        appendLog("info", "Connecting to event stream…", null);
        openEventStream(id);
        refreshSessions();
      }
      async function sendPrompt(text) {
        if (!selectedSession) return;
        appendLog("send", "→ " + text, null);
        try {
          const res = await apiFetch(
            "/v1/sessions/" + encodeURIComponent(selectedSession) + "/messages",
            { method: "POST", body: JSON.stringify({ text }) },
          );
          if (!res.ok) {
            appendLog("error", "HTTP " + res.status + ": " + (await res.text()), null);
            return;
          }
          const result = await res.json();
          appendLog(
            "done",
            "stopReason=" + result.stopReason + " · updates=" + (result.updates?.length ?? 0),
            null,
          );
        } catch (e) {
          appendLog("error", "Error: " + e.message, null);
        }
      }
      async function deleteSession() {
        if (!selectedSession) return;
        closeEventStream();
        await apiFetch("/v1/sessions/" + encodeURIComponent(selectedSession), {
          method: "DELETE",
        });
        selectedSession = null;
        $("session-detail").hidden = true;
        refreshSessions();
      }

      // ── SSE event stream + approvals ─────────────────────────────────────
      let sseCtrl = null;
      function closeEventStream() {
        if (sseCtrl) {
          sseCtrl.abort();
          sseCtrl = null;
        }
      }
      function timeStamp(ts) {
        const d = new Date(ts || Date.now());
        return d.toTimeString().slice(0, 8);
      }
      function appendLog(kind, body, extra) {
        const pane = $("response-pane");
        const entry = document.createElement("div");
        entry.className = "log-entry " + kind;
        const t = document.createElement("span");
        t.className = "log-time";
        t.textContent = timeStamp(extra?.at);
        const k = document.createElement("span");
        k.className = "log-kind";
        k.textContent = "[" + kind + "]";
        const b = document.createElement("span");
        b.className = "log-body";
        b.textContent = body;
        entry.append(t, k, b);
        if (extra?.actions) entry.appendChild(extra.actions);
        pane.appendChild(entry);
        pane.scrollTop = pane.scrollHeight;
        return entry;
      }
      function describeUpdate(payload) {
        const p = payload?.params || {};
        if (p.kind === "agent_message" || p.kind === "agent_message_chunk") {
          const text = typeof p.content === "string" ? p.content : (p.text || "");
          return "agent: " + text.slice(0, 140);
        }
        if (p.kind === "thinking" || p.kind === "agent_thought_chunk") {
          return "thinking";
        }
        if (p.kind === "tool_call" || p.kind === "tool_call_update") {
          const name = p.title || p.toolCallId || p.toolName || "tool";
          return "tool: " + name + (p.status ? " · " + p.status : "");
        }
        if (p.kind === "plan") return "plan";
        return payload?.method || JSON.stringify(payload).slice(0, 140);
      }
      function describeApproval(approval) {
        const params = approval.params || {};
        const tool = params.toolCall || {};
        const label = tool.title || tool.toolName || tool.kind || "tool call";
        return "approval needed: " + label;
      }
      function renderApproval(event) {
        const params = event.approval.params || {};
        const options = Array.isArray(params.options) ? params.options : [];
        const actions = document.createElement("div");
        actions.className = "log-actions";
        const renderOpts = options.length
          ? options
          : [
              { optionId: "allow_once", name: "Allow once", kind: "allow_once" },
              { optionId: "reject_once", name: "Deny", kind: "reject_once" },
            ];
        for (const opt of renderOpts) {
          const btn = document.createElement("button");
          btn.type = "button";
          btn.textContent = opt.name || opt.optionId;
          if (opt.kind && opt.kind.startsWith("reject")) btn.className = "danger";
          else if (opt.kind === "allow_always") btn.className = "success";
          btn.addEventListener("click", () =>
            submitApproval(event.approval.approvalId, opt.optionId, actions),
          );
          actions.appendChild(btn);
        }
        appendLog("approval", describeApproval(event.approval), { at: event.at, actions });
      }
      async function submitApproval(approvalId, optionId, actionsEl) {
        for (const btn of actionsEl.querySelectorAll("button")) btn.disabled = true;
        try {
          const res = await apiFetch(
            "/v1/sessions/" + encodeURIComponent(selectedSession) +
              "/approvals/" + encodeURIComponent(approvalId),
            { method: "POST", body: JSON.stringify({ outcome: "selected", optionId }) },
          );
          if (!res.ok) throw new Error("HTTP " + res.status);
          actionsEl.textContent = "responded: " + optionId;
        } catch (e) {
          appendLog("error", "Approval failed: " + e.message, null);
          for (const btn of actionsEl.querySelectorAll("button")) btn.disabled = false;
        }
      }
      function handleSseEvent(event) {
        if (event.type === "update") {
          appendLog("update", describeUpdate(event.payload), { at: event.at });
        } else if (event.type === "approval-request") {
          renderApproval(event);
        } else if (event.type === "session-closed") {
          appendLog("closed", "session closed", { at: event.at });
        }
      }
      async function openEventStream(id) {
        closeEventStream();
        const ctrl = new AbortController();
        sseCtrl = ctrl;
        const streamId = id;
        try {
          const res = await fetch(
            "/v1/sessions/" + encodeURIComponent(id) + "/events",
            { headers: { ...authHeader(), Accept: "text/event-stream" }, signal: ctrl.signal },
          );
          if (!res.ok || !res.body) {
            appendLog("error", "Stream open failed: HTTP " + res.status, null);
            return;
          }
          const reader = res.body.getReader();
          const decoder = new TextDecoder();
          let buf = "";
          while (selectedSession === streamId && sseCtrl === ctrl) {
            const { done, value } = await reader.read();
            if (done) break;
            buf += decoder.decode(value, { stream: true });
            let idx;
            while ((idx = buf.indexOf("\n\n")) >= 0) {
              const chunk = buf.slice(0, idx);
              buf = buf.slice(idx + 2);
              const dataLine = chunk.split("\n").find((l) => l.startsWith("data: "));
              if (!dataLine) continue;
              try {
                handleSseEvent(JSON.parse(dataLine.slice(6)));
              } catch (e) {
                appendLog("error", "Bad SSE frame: " + e.message, null);
              }
            }
          }
        } catch (e) {
          if (e.name !== "AbortError") appendLog("error", "Stream error: " + e.message, null);
        }
      }

      // ── Wiring ───────────────────────────────────────────────────────────
      document.getElementById("token-form").addEventListener("submit", (ev) => {
        ev.preventDefault();
        const t = $("token-input").value.trim();
        if (!t) return;
        setToken(t);
        showDashboard();
        loadMetrics("today");
        loadProjects();
        loadRateLimits();
      });
      document.querySelectorAll(".tabs button[data-tab]").forEach((btn) => {
        btn.addEventListener("click", () => {
          document
            .querySelectorAll(".tabs button[data-tab]")
            .forEach((b) => b.classList.remove("active"));
          btn.classList.add("active");
          const tab = btn.dataset.tab;
          $("tab-metrics").hidden = tab !== "metrics";
          $("tab-sessions").hidden = tab !== "sessions";
          if (tab === "sessions") refreshSessions();
        });
      });
      document.querySelectorAll(".range-tabs button[data-range]").forEach((btn) => {
        btn.addEventListener("click", () => {
          document
            .querySelectorAll(".range-tabs button[data-range]")
            .forEach((b) => b.classList.remove("active"));
          btn.classList.add("active");
          loadMetrics(btn.dataset.range);
        });
      });
      $("logout").addEventListener("click", () => {
        closeEventStream();
        clearToken();
        showAuth();
      });
      $("new-session-form").addEventListener("submit", async (ev) => {
        ev.preventDefault();
        const cwd = $("new-session-cwd").value.trim();
        if (!cwd) return;
        try {
          const res = await apiFetch("/v1/sessions", {
            method: "POST",
            body: JSON.stringify({ cwd }),
          });
          if (!res.ok) {
            const body = await res.text();
            $("sessions-list").innerHTML =
              '<div class="error">Create failed: ' + escape(body) + "</div>";
            return;
          }
          const session = await res.json();
          $("new-session-cwd").value = "";
          refreshSessions();
          selectSession(session.id);
        } catch (e) {
          $("sessions-list").innerHTML =
            '<div class="error">Create failed: ' + escape(e.message) + "</div>";
        }
      });
      $("prompt-form").addEventListener("submit", (ev) => {
        ev.preventDefault();
        const text = $("prompt-text").value.trim();
        if (!text) return;
        $("prompt-text").value = "";
        sendPrompt(text);
      });
      $("delete-session").addEventListener("click", () => deleteSession());

      if (getToken()) {
        showDashboard();
        loadMetrics("today");
        loadProjects();
        loadRateLimits();
      } else {
        showAuth();
      }
    </script>
  </body>
</html>
