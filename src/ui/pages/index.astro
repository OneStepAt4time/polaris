        $("session-detail").hidden = true;
        refreshSessions();
      }

      // ── SSE event stream + approvals ─────────────────────────────────────
      let sseCtrl = null;
      function closeEventStream() {
        if (sseCtrl) {
          sseCtrl.abort();
          sseCtrl = null;
        }
      }
      function timeStamp(ts) {
        const d = new Date(ts || Date.now());
        return d.toTimeString().slice(0, 8);
      }
      function appendLog(kind, body, extra) {
        const pane = $("response-pane");
        const entry = document.createElement("div");
        entry.className = "log-entry " + kind;
        const t = document.createElement("span");
        t.className = "log-time";
        t.textContent = timeStamp(extra?.at);
        const k = document.createElement("span");
        k.className = "log-kind";
        k.textContent = "[" + kind + "]";
        const b = document.createElement("span");
        b.className = "log-body";
        b.textContent = body;
        entry.append(t, k, b);
        if (extra?.actions) entry.appendChild(extra.actions);
        pane.appendChild(entry);
        pane.scrollTop = pane.scrollHeight;
        return entry;
      }
      // Naive Markdown renderer. Handles ``` code fences, `inline code`,
      // **bold**, *italic*, [text](url), and "- item" bullet lists. Anything
      // we don't recognize stays as plain text with <br> line breaks. The
      // text is HTML-escaped before formatting so user content can't inject
      // tags.
      function renderMarkdown(text) {
        const codeBlocks = [];
        const inlineCodes = [];
        let html = escape(String(text));
        html = html.replace(/```(\w*)\n?([\s\S]*?)```/g, (_m, _lang, code) => {
          codeBlocks.push(code);
          return "CB" + (codeBlocks.length - 1) + "";
        });
        html = html.replace(/`([^`\n]+)`/g, (_m, code) => {
          inlineCodes.push(code);
          return "IC" + (inlineCodes.length - 1) + "";
        });
        html = html.replace(/\*\*([^*\n]+)\*\*/g, "<strong>$1</strong>");
        html = html.replace(/(^|[\s(])\*([^*\n]+)\*(?=[\s).,;:!?]|$)/g, "$1<em>$2</em>");
        html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');
        html = html.replace(/^[-*] (.+)$/gm, "<li>$1</li>");
        html = html.replace(/(<li>[^]*?<\/li>(?:\n<li>[^]*?<\/li>)*)/g, "<ul>$1</ul>");
        html = html.replace(/\n/g, "<br>");
        html = html.replace(/CB(\d+)/g, (_m, idx) =>
          '<pre class="code-block"><code>' + codeBlocks[Number(idx)] + "</code></pre>",
        );
        html = html.replace(/IC(\d+)/g, (_m, idx) =>
          '<code class="inline-code">' + inlineCodes[Number(idx)] + "</code>",
        );
        return html;
      }

      // Streaming state for agent_message_chunk: chunks accumulate into one
      // log entry instead of creating N adjacent "[update]" lines.
      let currentAssistantEntry = null;
      let currentAssistantText = "";
      const toolCallEntries = new Map();
      const thinkingEntries = new Map();

      function newLogShell(kind, at) {
        const pane = $("response-pane");
        const entry = document.createElement("div");
        entry.className = "log-entry " + kind;
        const t = document.createElement("span");
        t.className = "log-time";
        t.textContent = timeStamp(at);
        const k = document.createElement("span");
        k.className = "log-kind";
        k.textContent = "[" + kind + "]";
        entry.append(t, k);
        pane.appendChild(entry);
        return entry;
      }
      function scrollLogToBottom() {
        const pane = $("response-pane");
        pane.scrollTop = pane.scrollHeight;
      }
      function finalizeAssistantEntry() {
        currentAssistantEntry = null;
        currentAssistantText = "";
      }
      function renderAssistantChunk(text, at) {
        if (currentAssistantEntry === null) {
          const entry = newLogShell("assistant", at);
          const body = document.createElement("div");
          body.className = "log-body markdown";
          entry.appendChild(body);
          currentAssistantEntry = body;
          currentAssistantText = "";
        }
        currentAssistantText += text;
        currentAssistantEntry.innerHTML = renderMarkdown(currentAssistantText);
        scrollLogToBottom();
      }
      function renderThinkingChunk(text, at, key) {
        let entry = key ? thinkingEntries.get(key) : null;
        if (!entry) {
          const shell = newLogShell("thinking", at);
          const body = document.createElement("div");
          body.className = "log-body";
          body.dataset.text = "";
          shell.appendChild(body);
          entry = body;
          if (key) thinkingEntries.set(key, entry);
