        const next = (entry.dataset.text ?? "") + text;
        entry.dataset.text = next;
        entry.textContent = next.length > 200 ? next.slice(0, 200) + "…" : next;
        scrollLogToBottom();
      }
      function extractToolText(c) {
        if (typeof c === "string") return c;
        if (c && typeof c === "object") {
          if (typeof c.text === "string") return c.text;
          if (typeof c.content === "string") return c.content;
          if (c.type === "text" && typeof c.text === "string") return c.text;
        }
        return null;
      }
      function buildToolContentBlock(p) {
        const pieces = [];
        const input = p.rawInput ?? p.input;
        if (input !== undefined) {
          try {
            pieces.push("input:\n" + JSON.stringify(input, null, 2));
          } catch {
            pieces.push("input: " + String(input));
          }
        }
        const content = p.content ?? p.rawOutput ?? p.output;
        if (Array.isArray(content)) {
          for (const c of content) {
            const t = extractToolText(c);
            if (t !== null) pieces.push(t);
          }
        } else if (content !== undefined) {
          const t = extractToolText(content);
          if (t !== null) pieces.push(t);
          else {
            try {
              pieces.push(JSON.stringify(content, null, 2));
            } catch {
              pieces.push(String(content));
            }
          }
        }
        return pieces.length > 0 ? pieces.join("\n") : null;
      }
      function renderToolCall(p, at) {
        const id = p.toolCallId || p.id || `unkeyed-${Date.now()}-${Math.random()}`;
        let entry = toolCallEntries.get(id);
        if (!entry) {
          const shell = newLogShell("tool", at);
          const block = document.createElement("div");
          block.className = "tool-call";
          shell.appendChild(block);
          entry = {
            block,
            header: null,
            name: null,
            status: null,
            toggle: null,
            locations: null,
            content: null,
            params: {},
          };
          const header = document.createElement("div");
          header.className = "tool-call-header";
          const name = document.createElement("span");
          name.className = "tool-name";
          const status = document.createElement("span");
          status.className = "tool-status pending";
          status.textContent = "pending";
          const toggle = document.createElement("button");
          toggle.type = "button";
          toggle.className = "tool-toggle";
          toggle.textContent = "show content";
          toggle.addEventListener("click", () => {
            if (!entry.content) return;
