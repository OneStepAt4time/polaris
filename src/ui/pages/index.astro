          });
        });
      }
      async function resumeSession(id, cwd, btn) {
        btn.disabled = true;
        const original = btn.textContent;
        btn.textContent = "Resuming…";
        try {
          const res = await apiFetch("/v1/sessions/" + encodeURIComponent(id) + "/resume", {
            method: "POST",
            body: JSON.stringify({ cwd }),
          });
          if (!res.ok) {
            const body = await res.json().catch(() => ({}));
            const detail = body.detail || body.error || "HTTP " + res.status;
            btn.textContent = "Resume failed";
            appendLog("error", "Resume failed: " + detail, null);
            setTimeout(() => {
              btn.textContent = original;
              btn.disabled = false;
            }, 3000);
            return;
          }
          await refreshSessions();
          selectSession(id);
        } catch (e) {
          btn.textContent = "Resume failed";
          appendLog("error", "Resume error: " + e.message, null);
          setTimeout(() => {
            btn.textContent = original;
            btn.disabled = false;
          }, 3000);
        }
      }
      async function selectSession(id) {
