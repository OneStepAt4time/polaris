            entry.block.appendChild(entry.locations);
          }
          entry.locations.textContent = locs
            .map((l) => l.path || l).filter(Boolean).join(" · ");
        }
        const text = buildToolContentBlock(merged);
        if (text !== null) {
          if (!entry.content) {
            entry.content = document.createElement("pre");
            entry.content.className = "tool-content";
            entry.content.setAttribute("hidden", "");
            entry.block.appendChild(entry.content);
          }
          entry.content.textContent = text;
        } else if (entry.toggle) {
          entry.toggle.style.display = "none";
        }
        scrollLogToBottom();
      }
      function renderPlan(p, at) {
        const shell = newLogShell("plan", at);
        const body = document.createElement("div");
        body.className = "log-body markdown";
        const steps = Array.isArray(p.entries) ? p.entries : Array.isArray(p.steps) ? p.steps : [];
        if (steps.length > 0) {
          body.innerHTML =
            "<ul>" +
            steps
              .map((s) => {
                const t = typeof s === "string" ? s : s.title || s.text || s.content || "";
